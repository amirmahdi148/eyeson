---
import Header from "../islands/Shared/MegaMenu.tsx";
import Footer from "../components/Shared/Footer.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  lang?: string;
  keywords?: string;
  datePublished?: string;
  dateModified?: string;
  articleSection?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = "/og/image.jpg",
  ogType = "website",
  robots,
  lang = "en",
  keywords,
  datePublished,
  dateModified,
  articleSection,
} = Astro.props as Props;

const defaultTitle = () => {
  const path = Astro.url.pathname.replace(/^\//, "").replace(/\/$/, "");
  if (!path) return "EyesOn Agency — Creative Digital Agency";
  const parts = path.split("/").map((p) => p.charAt(0).toUpperCase() + p.slice(1));
  return `${parts.join(" ")} — EyesOn Agency`;
};

const computedTitle = title ?? defaultTitle();
const computedDescription = description ?? "EyesOn Studio: Premium Animations & Video Editing services.";


const finalTitle = title ?? computedTitle;
const finalDescription = description ?? computedDescription;

const deploymentHost = process.env.VERCEL_URL || Astro.url.host;
const origin = `${Astro.url.protocol}//${deploymentHost}`;
const absoluteOgImage = ogImage?.startsWith("http") ? ogImage : new URL(ogImage, origin).href;
const resolvedCanonical = canonicalUrl ?? `${origin}${Astro.url.pathname}`;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <meta name="theme-color" content="#000E17" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <link rel="canonical" href={resolvedCanonical} />
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={resolvedCanonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:site" content="@eyesonagency" />
    <meta name="twitter:creator" content="@eyesonagency" />

    {keywords && <meta name="keywords" content={keywords} />}
    {ogType === "article" && <meta name="author" content="EyesOn Studio" />}
    <meta name="format-detection" content="telephone=no, email=no" />

    {datePublished && <meta property="article:published_time" content={datePublished} />}
    {dateModified && <meta property="article:modified_time" content={dateModified} />}
    {articleSection && <meta property="article:section" content={articleSection} />}

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "EyesOn Agency",
      "url": "https://eyeson.com",
      "logo": "https://eyeson.com/og/image.jpg",
      "description": "Premium Animations & Video Editing services.",
      "sameAs": [
        "https://twitter.com/eyesonagency",
        "https://www.linkedin.com/company/eyesonagency"
      ]
    })} />
  </head>

  <body class="bg-[#000E17] text-white overflow-x-hidden" transition:animate="fade">
    <Header client:load />

    {/* اضافه شدن pt-24 lg:pt-32 برای جلوگیری از رفتن محتوا به زیر هدر */}
    <main class="min-w-0 overflow-x-hidden pt-8 lg:pt-10">
      <slot />
    </main>

    <Footer />


    <script>
      import type Lenis from "lenis";

      const isFirefox = navigator.userAgent.toLowerCase().includes('firefox');

      if (!isFirefox) {
        let lenis: Lenis;
        let rafId = 0;

        async function initSmoothScrolling() {
          if (lenis) lenis.destroy();
          if (rafId) cancelAnimationFrame(rafId);

          const Lenis = (await import('lenis')).default;

          lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            smoothWheel: true,
            wheelMultiplier: 1,
            touchMultiplier: 2,
            gestureOrientation: 'vertical',
          });

          function raf(time: number) {
            lenis.raf(time);
            rafId = requestAnimationFrame(raf);
          }

          rafId = requestAnimationFrame(raf);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => initSmoothScrolling(), { once: true });
        } else {
          initSmoothScrolling();
        }

        document.addEventListener('astro:page-load', () => initSmoothScrolling());
      }
    </script>

    <script is:inline>
      console.log('[Analytics] script loaded', window.location.pathname);

      const endpoint = '/api/analytics/receive/v1';
      console.log('[Analytics] endpoint:', endpoint);

      const payload = {
        event: 'pageview',
        path: window.location.pathname,
        userAgent: navigator.userAgent,
      };
      const body = JSON.stringify(payload);
      console.log('[Analytics] sending:', body);

      const sent = navigator.sendBeacon(endpoint, new Blob([body], {type: 'application/json'}));
      console.log('[Analytics] sendBeacon result:', sent);

      if (!sent) {
        fetch(endpoint, { method: 'POST', body: body, headers: { 'Content-Type': 'application/json' }, keepalive: true })
          .then(function(r) { console.log('[Analytics] fetch fallback status:', r.status); })
          .catch(function(e) { console.log('[Analytics] fetch fallback error:', e.message); });
      }

      fetch('/api/client-ip')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          const ip = data.ip || '';
          const raw = ip + '|' + navigator.userAgent;
          let hash = 0;
          for (let i = 0; i < raw.length; i++) {
            const c = raw.charCodeAt(i);
            hash = ((hash << 5) - hash) + c;
            hash |= 0;
          }
          const enriched = {
            event: 'pageview',
            hash: Math.abs(hash).toString(36),
            path: window.location.pathname,
            userAgent: navigator.userAgent,
          };
          navigator.sendBeacon(endpoint, new Blob([JSON.stringify(enriched)], { type: 'application/json' }));
          console.log('[Analytics] enriched sent');
        })
        .catch(function(err) {
          console.log('[Analytics] ip fetch skipped:', err.message);
        });
    </script>


    <style is:global>
      
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #183945; 
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom, #31d1a6, #25aeb2);
        border-radius: 8px;
        border: 2px solid #183945; 
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(to bottom, #31d1a6, #31d1a6);
      }

      /* --- استایل اسکرول‌بار برای فایرفاکس --- */
      * {
        scrollbar-width: thin;
        scrollbar-color: #31d1a6 #183945;
      }

      /* --- استایل‌های ضروری برای عملکرد درست Lenis --- */
      html.lenis {
        scroll-behavior: auto;
      }

      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }

      .lenis.lenis-stopped {
        overflow: hidden;
      }

      .lenis.lenis-smooth iframe {
        pointer-events: none;
      }
    </style>
  </body>
</html>
