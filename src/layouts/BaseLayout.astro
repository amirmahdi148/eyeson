---
import Header from "../islands/Shared/MegaMenu.tsx";
import Footer from "../components/Shared/Footer.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  lang?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = "/og/image.jpg",
  ogType = "website",
  robots,
  lang = "en",
} = Astro.props as Props;

const defaultTitle = () => {
  const path = Astro.url.pathname.replace(/^\//, "").replace(/\/$/, "");
  if (!path) return "EyesOn Agency — Creative Digital Agency";
  const parts = path.split("/").map((p) => p.charAt(0).toUpperCase() + p.slice(1));
  return `${parts.join(" ")} — EyesOn Agency`;
};

const computedTitle = title ?? defaultTitle();
const computedDescription = description ?? "EyesOn Studio: Premium Animations & Video Editing services.";


const finalTitle = title ?? computedTitle;
const finalDescription = description ?? computedDescription;

const deploymentHost = process.env.VERCEL_URL || Astro.url.host;
const origin = `${Astro.url.protocol}//${deploymentHost}`;
const absoluteOgImage = ogImage?.startsWith("http") ? ogImage : new URL(ogImage, origin).href;
const resolvedCanonical = canonicalUrl ?? `${origin}${Astro.url.pathname}`;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <meta name="theme-color" content="#000E17" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="canonical" href={resolvedCanonical} />
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={resolvedCanonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
  </head>

  <body class="bg-[#000E17] text-white overflow-x-hidden" transition:animate="fade">
    <Header client:load />

    {/* اضافه شدن pt-24 lg:pt-32 برای جلوگیری از رفتن محتوا به زیر هدر */}
    <main class="min-w-0 overflow-x-hidden pt-8 lg:pt-10">
      <slot />
    </main>

    <Footer />

    {/* ========================================== */}
    {/* 1. کدهای جاوااسکریپت Lenis */}
    {/* ========================================== */}
    <script>
      const isFirefox = navigator.userAgent.toLowerCase().includes('firefox');

      if (!isFirefox) {
        let lenis: Lenis;
        let rafId = 0;

        async function initSmoothScrolling() {
          if (lenis) lenis.destroy();
          if (rafId) cancelAnimationFrame(rafId);

          const Lenis = (await import('lenis')).default;

          lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            smoothWheel: true,
            wheelMultiplier: 1,
            touchMultiplier: 2,
            gestureOrientation: 'vertical',
          });

          function raf(time: number) {
            lenis.raf(time);
            rafId = requestAnimationFrame(raf);
          }

          rafId = requestAnimationFrame(raf);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => initSmoothScrolling(), { once: true });
        } else {
          initSmoothScrolling();
        }

        document.addEventListener('astro:page-load', () => initSmoothScrolling());
      }
    </script>

    {/* ========================================== */}
    {/* 2. استایل‌های اسکرول‌بار و الزامات Lenis */}
    {/* ========================================== */}
    <style is:global>
      /* --- استایل اسکرول‌بار مرورگرهای کرومیوم --- */
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #183945; 
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom, #31d1a6, #25aeb2);
        border-radius: 8px;
        border: 2px solid #183945; 
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(to bottom, #31d1a6, #31d1a6);
      }

      /* --- استایل اسکرول‌بار برای فایرفاکس --- */
      * {
        scrollbar-width: thin;
        scrollbar-color: #31d1a6 #183945;
      }

      /* --- استایل‌های ضروری برای عملکرد درست Lenis --- */
      html.lenis {
        scroll-behavior: auto;
      }

      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }

      .lenis.lenis-stopped {
        overflow: hidden;
      }

      .lenis.lenis-smooth iframe {
        pointer-events: none;
      }
    </style>
  </body>
</html>
