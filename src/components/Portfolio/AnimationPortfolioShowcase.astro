---
import { SmartImage } from "../../utils/SmartImage.tsx";

const showcaseItems = [
  {
    id: "wide-1",
    title: "Lottie Animation",
    category: "Lottie Animation",
    src: "/portfolio/showcase/wide-1.webp",
    className: "md:col-span-2 md:row-span-2",
  },
  {
    id: "tall-1",
    title: "UI Animation",
    category: "UI Animation",
    src: "/portfolio/showcase/tall-1.webp",
    className: "md:row-span-2",
  },
  {
    id: "card-1",
    title: "Branded Motion",
    category: "Branded Motion",
    src: "/portfolio/showcase/card-1.webp",
    className: "",
  },
  {
    id: "card-2",
    title: "UI Animation",
    category: "UI Animation",
    src: "/portfolio/showcase/card-2.webp",
    className: "",
  },
  {
    id: "card-3",
    title: "Lottie Animation",
    category: "Lottie Animation",
    src: "/portfolio/showcase/card-3.webp",
    className: "",
  },
];
---

<section class="portfolio-reveal mx-auto w-full max-w-6xl px-4 pb-20 sm:px-6">
  <!-- HEADER -->
  <div class="mx-auto max-w-2xl text-center">
    <span class="tracking-[0.2em] font-thin text-sm">OUR WORK</span>
    <h2
      class="bg-linear-to-r from-[#46B6A0] to-[#2EBACA] bg-clip-text text-3xl font-black text-transparent sm:text-4xl md:text-5xl"
    >
      Animation portfolio
    </h2>
    <p class="mt-3 text-sm leading-6 text-white/70 sm:text-base">
      Animation works when it communicates, not just decorates.
    </p>
  </div>

  <!-- 📱 MOBILE (فقط 4 تا - ستون) -->
  <div class="mt-8 flex flex-col gap-4 sm:hidden">
    {
      showcaseItems.slice(0, 4).map((item) => (
        <article class="relative overflow-hidden rounded-2xl border border-white/10 bg-[#071A28] h-[180px]">
          <SmartImage
            src={item.src}
            alt={item.title}
            fill={true}
            className="object-cover"
          />
          <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/70 to-transparent p-3">
            <span class="text-xs text-white/85">{item.category}</span>
          </div>
        </article>
      ))
    }
  </div>

  <!-- 💻 DESKTOP / TABLET (همه آیتم‌ها با گرید اصلی) -->
  <div
    class="mt-8 hidden sm:grid auto-rows-[220px] grid-cols-2 gap-4 md:grid-cols-3"
  >
    {
      showcaseItems.map((item) => (
        <article
          class={`group relative overflow-hidden rounded-2xl border border-white/10 bg-[#071A28] ${item.className}`}
        >
          <SmartImage
            src={item.src}
            alt={item.title}
            fill={true}
            className="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-linear-to-t from-black/70 to-transparent p-3">
            <span class="inline-block rounded-md border border-white/20 bg-black/40 px-2 py-1 text-xs text-white/85">
              {item.category}
            </span>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .portfolio-reveal {
    animation: portfolioRevealUp 0.7s ease both;
  }

  @keyframes portfolioRevealUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
