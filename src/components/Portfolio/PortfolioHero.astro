---
import { SmartImage } from "../../utils/SmartImage.tsx";
---

<style>
    @keyframes floatXLeft {
        0%, 100% { transform: translate3d(0,0,0); }
        50% { transform: translate3d(-15px,0,0); }
    }

    @keyframes floatXRight {
        0%, 100% { transform: translate3d(0,0,0); }
        50% { transform: translate3d(15px,0,0); }
    }

    .animate-left {
        animation: floatXLeft 4s ease-in-out infinite;
        will-change: transform;
    }

    .animate-right {
        animation: floatXRight 4s ease-in-out infinite;
        will-change: transform;
    }

    /* 🚀 موبایل = بدون انیمیشن + بدون لود تصویر */
    @media (max-width: 768px) {
        .animate-left,
        .animate-right {
            animation: none;
        }
    }
</style>

<div class="h-200 flex items-center justify-between relative overflow-hidden">

    <!-- Left Image (فقط دسکتاپ) -->
    <div class="absolute left-1 top-40 animate-left hidden md:block">
        <div class="w-100 h-55">
            <SmartImage
                    src="/portfolio/left.png"
                    width={400}
                    height={220}
            />
        </div>
    </div>

    <!-- Center Content -->
    <div class="flex flex-col items-center text-center w-full px-4">

        <!-- Badge -->
        <div class="mb-6">
            <div class="flex items-center gap-4 px-4 py-2 rounded-full
                bg-linear-to-r from-teal-500/20 to-transparent
                border border-white/20 backdrop-blur-sm md:backdrop-blur-md
                shadow-[0_0_10px_rgba(20,184,166,0.2)] md:shadow-[0_0_30px_rgba(20,184,166,0.2)]">

                <div class="relative w-10 h-10 flex items-center justify-center rounded-full border-2 border-teal-400">
                    <div class="w-4 h-4 bg-teal-400 rounded-full"></div>
                </div>

                <span class="text-white text-lg font-medium tracking-wide -ml-2">
                    About Us
                </span>
            </div>
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6">
            We're <span class="text-teal-400">EyesOn</span> Studio
        </h1>

        <!-- Description -->
        <p class="text-gray-300 max-w-2xl mb-10 text-sm md:text-base">
            A team of motion designers, video editors, and creative strategists
            obsessed with creating content that converts
        </p>

        <!-- Stats -->
        <div class="flex items-center gap-5 md:gap-16 mb-12 text-white">

            <div>
                <h2 class="text-xl md:text-2xl font-bold">2000+</h2>
                <p class="text-white text-xs md:text-sm font-thin">Projects Delivered</p>
            </div>

            <hr class="w-[1.5px] h-13.75 border-none bg-linear-to-b from-transparent via-white to-transparent opacity-70" />

            <div>
                <h2 class="text-xl md:text-2xl font-bold">10+</h2>
                <p class="text-white text-xs md:text-sm font-thin">Years Experience</p>
            </div>

            <hr class="w-[1.5px] h-13.75 border-none bg-linear-to-b from-transparent via-white to-transparent opacity-70" />

            <div>
                <h2 class="text-xl md:text-2xl font-bold">98%</h2>
                <p class="text-white text-xs md:text-sm font-thin">Client Satisfaction</p>
            </div>

        </div>

        <!-- Buttons -->
        <div class="mt-6 flex flex-row flex-wrap justify-center gap-3">

            <!-- Primary -->
            <div class="relative inline-flex rounded-full p-0.5">
                <div class="absolute -inset-0.5 rounded-full bg-linear-to-r from-[#45B6A0] to-[#12ACB5] shadow-[0_0_12px_#00A9BD]" />
                <a
                        href="#"
                        class="relative z-10 rounded-full px-5 py-2.5 bg-linear-to-r from-[#00A9BD] to-[#1D553A] text-sm md:text-lg"
                >
                    Get free sample
                </a>
            </div>

            <!-- Secondary -->
            <div class="relative inline-flex rounded-full p-0.5">
                <div class="absolute -inset-0.5 rounded-full bg-linear-to-r from-[#056E7C] to-[#46B6A0] shadow-[0_0_12px_#00A9BD]" />
                <a
                        href="#"
                        class="relative z-10 rounded-full px-5 py-2.5 bg-linear-to-r from-[#00061D] to-[#0B1F2A] text-sm md:text-lg"
                >
                    See our work
                </a>
            </div>

        </div>

    </div>

    <!-- Right Image (فقط دسکتاپ) -->
    <div class="absolute right-1 top-40 animate-right hidden md:block">
        <div class="w-100 h-55">
            <SmartImage
                    src="/portfolio/right.png"

                    width={400}
                    height={220}
            />
        </div>
    </div>

</div>