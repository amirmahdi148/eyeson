---
import {
  OrbitSystem,
  type OrbitConfig,
  content,
} from "../../islands/Shared/OrbitSystem";
import { buildOrbitIcon } from "../../lib/orbitIcons.ts";
import { ToolsComponent } from "../../islands/About/ToolsWeUse.tsx";
import { Hero } from "../../islands/About/Hero.tsx";
import { Communication } from "../../islands/About/Communication";
import VideoWorkShowcaseSection from "../../islands/Shared/VideoWorkShowcaseSection";
import QandASection from "../Shared/QandASection.astro";
import ContactUs from "../../islands/ContactUs";

const orbits: OrbitConfig[] = [
  {
    pathD: "M500,10 a470,470 0 1,0 0,1300 a470,470 0 1,0 0,-1300",
    color: "#00A9BD",
    icons: [
      buildOrbitIcon("icon-1", -0.1, 0.4),
      buildOrbitIcon("icon-2", 0.1, 0.6),
      buildOrbitIcon("icon-3", 0.7, 1.2),
      buildOrbitIcon("icon-4", 0.8, 1.3),
      buildOrbitIcon("icon-5", 1.0, 1.5),
    ],
  },
  {
    pathD: "M500,110 a370,370 0 1,0 0,1100 a370,370 0 1,0 0,-1100",
    color: "#00A9BD",
    icons: [
      buildOrbitIcon("icon-6", -0.04, 0.4),
      buildOrbitIcon("icon-7", 0.05, 0.6),
      buildOrbitIcon("icon-8", 0.85, 1.2),
    ],
  },
  {
    pathD: "M500,210 a270,270 0 1,0 0,900 a270,270 0 1,0 0,-900",
    color: "#38B6B3",
    icons: [
      buildOrbitIcon("icon-9", 0, 0.5),
      buildOrbitIcon("icon-10", 0.25, 0.75),
      buildOrbitIcon("icon-11", 0.5, 1.0),
      buildOrbitIcon("icon-12", 0.75, 1.25),
    ],
  },
];

const aboutShowcaseFirstRow = [
  { id: 1, src: "/slider1.webp", alt: "Lighting effect sample" },
  {
    id: 2,
    src: "/animation-section/video.webp",
    alt: "Before and after portrait sample",
  },
  { id: 3, src: "/videoEditing.webp", alt: "Editing timeline sample" },
  {
    id: 4,
    src: "/animation-section/short-form.webp",
    alt: "Mobile editing preview sample",
  },
];

const aboutShowcaseSecondRow = [
  { id: 5, src: "/animation-section/video.webp", alt: "Portrait edit sample" },
  {
    id: 6,
    src: "/animation-section/short-form.webp",
    alt: "Social media sample",
  },
  { id: 7, src: "/videoEditing.webp", alt: "Post-production timeline sample" },
  { id: 8, src: "/slider1.webp", alt: "Color effect sample" },
];
---

<div class="bg-[#000E17]">
  <Hero client:load />
  <OrbitSystem
    orbits={orbits}
    content={content}
    width="1000px"
    height="1000px"
    animations={true}
    client:load
  />
  <Communication client:load />
  <ToolsComponent client:load />
  <VideoWorkShowcaseSection
    client:load
    eyebrow="OUR WORK"
    title="Who we work with"
    highlight={null}
    description="Our clients come from every corner of the world, collaborating with us from the US, UK, Europe, and beyond. At eyeson, we partner closely with SaaS teams, tech companies, and digital-first brands that value clarity, design consistency, and strong visual storytelling."
    firstRow={aboutShowcaseFirstRow}
    secondRow={aboutShowcaseSecondRow}
    sectionClassName="pt-4 sm:pt-6 lg:pt-8"
    titleClassName="mt-3 text-4xl font-bold leading-tight text-[#2bd0c7] sm:mt-4 sm:text-5xl lg:text-6xl"
    descriptionClassName="mx-auto mt-4 max-w-3xl text-sm leading-7 text-[#b9c8d0] sm:mt-5 sm:text-base"
    fadeColor="#000E17"
  />
  <QandASection />
  <ContactUs client:visible />
</div>
