---
const questions = [
  {
    id: 1,
    q: "What is motion graphics?",
    a: "Motion graphics is the art of animating graphic elements to tell stories, explain ideas, or bring branding to life. It includes animated logos, kinetic typography, and visuals used in ads, explainers, and social content.",
  },
  {
    id: 2,
    q: "Why is visual content important for my business?",
    a: "Visual content is crucial because it captures attention, conveys messages quickly, and enhances brand recognition.",
  },
  {
    id: 3,
    q: "What services do you offer?",
    a: "We offer logo animations, explainer videos, social media graphics, and more.",
  },
  {
    id: 4,
    q: "What is your production process?",
    a: "We go from concept → design → animation → delivery with full collaboration.",
  },
  {
    id: 5,
    q: "What if I don't know exactly what I want?",
    a: "That’s completely fine. We help shape the direction, define the message, and guide you through the process.",
  },
];

const QAImg = "/Shared/QandA.png";
---

<section class="relative overflow-hidden px-4 py-16 text-white sm:px-6 md:px-10 md:py-24">
  <div class="relative mx-auto grid w-full max-w-7xl gap-10 lg:grid-cols-[380px_1fr] lg:gap-12 lg:items-start">
    
    {/* ===== بخش هدر و تصویر سمت چپ ===== */}
    <div class="space-y-6 sm:space-y-8 flex flex-col items-center text-center lg:items-start lg:text-left">
      <div class="w-full qa-reveal fade-up">
        <h2 class="text-3xl font-extrabold leading-tight sm:text-4xl md:text-5xl">
          <span class="block">Your Questions</span>
          <span class="block text-[#39d0c3] drop-shadow-[0_0_15px_rgba(57,208,195,0.4)]">Answered</span>
        </h2>
        <p class="mt-4 sm:mt-5 max-w-md text-[15px] leading-7 text-white/70 md:text-base mx-auto lg:mx-0 font-light">
          Find answers to common questions about Eyeson and our services.
        </p>
      </div>

      {/* تصویر سمت چپ */}
      <img
          src={QAImg}
          alt="Questions and answers illustration"
          class="qa-reveal fade-up delay-100 hidden w-[280px] sm:w-[320px] select-none object-contain opacity-95 md:block drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)] transform-gpu transition-transform duration-700 hover:scale-105 hover:-translate-y-2"
          loading="lazy"
          decoding="async"
      />
    </div>

    {/* ===== بخش آکوردیون (سوالات) ===== */}
    <div class="w-full">
      <div class="space-y-3 sm:space-y-4">
        {questions.map((item, index) => (
            <div
                class={`qa-item qa-reveal fade-left overflow-hidden rounded-xl sm:rounded-2xl border bg-[#06242B] transition-all duration-400 ease-out shadow-lg hover:shadow-xl ${
                    index === 0 ? "is-open bg-[#07323B] border-cyan-400/40 shadow-[0_0_20px_rgba(57,208,195,0.1)]" : "border-cyan-400/15 hover:border-cyan-400/30 hover:bg-[#072830]"
                }`}
                style={`transition-delay: ${index * 100}ms;`}
                data-qa-index={index}
            >
              <button
                  type="button"
                  class="qa-trigger flex w-full items-start sm:items-center justify-between gap-3 sm:gap-4 px-4 py-4 sm:px-5 md:px-6 md:py-5 text-left group"
                  aria-expanded={index === 0 ? "true" : "false"}
                  aria-controls={`qa-panel-${index}`}
              >
                <span class="text-[15px] sm:text-base md:text-lg font-semibold leading-relaxed text-white/90 group-hover:text-white transition-colors pr-2">
                  <span class="text-white/50 group-hover:text-cyan-400/80 transition-colors mr-1">{item.id}.</span>
                  {item.q}
                </span>

                <span class="qa-icon mt-0.5 sm:mt-0 inline-flex h-6 w-6 sm:h-8 sm:w-8 shrink-0 items-center justify-center text-[#39d0c3] transition-transform duration-300 group-hover:scale-110">
                <svg class="qa-icon-plus transition-transform duration-300" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <svg class="qa-icon-close transition-transform duration-300 rotate-90" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
              </button>

              <div
                  id={`qa-panel-${index}`}
                  class={`qa-panel px-4 sm:px-5 md:px-6 ${index === 0 ? "is-open" : "is-collapsed"}`}
                  role="region"
                  aria-label={item.q}
              >
                <div class="pb-4 sm:pb-5 md:pb-6">
                  <div class="mb-4 h-px w-full bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

                  <div class="flex items-start gap-3 sm:gap-4">
                  {/* دایره A */}
                  <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-400/10 border border-cyan-400/20 text-[11px] font-bold text-cyan-400 shadow-[0_0_10px_rgba(57,208,195,0.15)]">
                    A
                  </span>
                    <p class="max-w-4xl text-[14px] sm:text-sm leading-relaxed sm:leading-7 text-white/70 font-light">
                      {item.a}
                    </p>
                  </div>
                </div>
              </div>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ================= انیمیشن‌های اسکرول ================= */
  .qa-reveal {
    opacity: 0;
    will-change: opacity, transform;
  }

  .fade-up {
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fade-left {
    transform: translateX(30px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .qa-reveal.is-visible {
    opacity: 1;
    transform: translate(0);
  }

  .delay-100 { transition-delay: 0.15s; }

  /* ================= منطق آکوردیون (CSS Grid Trick) ================= */
  .qa-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(-8px);
    transition: 
        grid-template-rows 400ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 300ms ease,
        transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .qa-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .qa-panel > div {
    overflow: hidden;
  }

  /* ================= تغییر وضعیت آیکون‌ها ================= */
  .qa-icon-plus { display: block; }
  .qa-icon-close { display: none; }

  .qa-item.is-open .qa-icon-plus { display: none; }
  .qa-item.is-open .qa-icon-close { display: block; transform: rotate(0deg); }

  .qa-trigger {
    -webkit-tap-highlight-color: transparent;
  }
</style>

<script is:inline>
  function initQA() {
    // 1. منطق انیمیشن اسکرول
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealElements = document.querySelectorAll('.qa-reveal');
    
    if (prefersReducedMotion) {
      revealElements.forEach(el => el.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      }, { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 });

      revealElements.forEach(el => observer.observe(el));
    }

    // 2. منطق آکوردیون
    const items = Array.from(document.querySelectorAll(".qa-item"));

    const setState = (item, open) => {
      const trigger = item.querySelector(".qa-trigger");
      const panel = item.querySelector(".qa-panel");
      if (!trigger || !panel) return;

      item.classList.toggle("is-open", open);
      
      // تغییر استایل دایو اصلی موقع باز شدن
      if(open) {
        item.classList.add("bg-[#07323B]", "border-cyan-400/40", "shadow-[0_0_20px_rgba(57,208,195,0.1)]");
        item.classList.remove("border-cyan-400/15");
      } else {
        item.classList.remove("bg-[#07323B]", "border-cyan-400/40", "shadow-[0_0_20px_rgba(57,208,195,0.1)]");
        item.classList.add("border-cyan-400/15");
      }

      trigger.setAttribute("aria-expanded", open ? "true" : "false");
      panel.classList.toggle("is-open", open);
      panel.classList.toggle("is-collapsed", !open);
    };

    // ریست کردن ایونت لیسنرها (برای Astro View Transitions)
    items.forEach((item) => {
      const trigger = item.querySelector(".qa-trigger");
      if (!trigger) return;
      
      // کلون کردن المنت برای حذف ایونت‌های قبلی
      const newTrigger = trigger.cloneNode(true);
      trigger.parentNode.replaceChild(newTrigger, trigger);

      newTrigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        
        // بستن بقیه
        items.forEach((other) => setState(other, false));
        
        // باز کردن آیتم کلیک شده
        if (!isOpen) {
          setState(item, true);
        }
      });
    });
  }

  // اجرا در لود اولیه و جابجایی بین صفحات در Astro
  document.addEventListener("DOMContentLoaded", initQA);
  document.addEventListener("astro:page-load", initQA);
</script>