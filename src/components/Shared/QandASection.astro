---
import { SmartImage } from "../../utils/SmartImage";

type QAItem = {
  id: number;
  q: string;
  a: string;
};

type QAOverride = {
  id: number;
  q?: string | null;
  a?: string | null;
};

type Props = {
  questions?: QAOverride[];
  title1?: string;
  title2?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
};

const DEFAULT_QUESTIONS: QAItem[] = [
  {
    id: 1,
    q: "What does EyesOn Studio create?",
    a: "EyesOn Studio creates premium motion graphics, product launch videos, SaaS explainers,\n" +
        "AI product videos, short-form social content, talking head edits, animations, UI visuals, ad\n" +
        "creatives, and brand design assets for modern brands.",
  },
  {
    id: 2,
    q: "Who do you usually work with?",
    a: "We work with startups, SaaS companies, AI brands, crypto and fintech teams, agencies,\n" +
        "founders, creators, and growing businesses that need high-quality visual content without\n" +
        "building a full creative team in-house.",
  },
  {
    id: 3,
    q: "Do you work with SaaS, AI, and tech companies?",
    a: "Yes. SaaS, AI, apps, crypto, fintech, and tech brands are a strong fit for us because we\n" +
        "specialize in turning complex products into visuals people understand quickly. We help\n" +
        "explain dashboards, features, workflows, product benefits, and technical ideas in a simple,\n" +
        "premium, and engaging way.",
  },
  {
    id: 4,
    q: "Can you help with the script and concept?",
    a: "Yes. You do not need to come with a perfect script or clear idea. We can help shape the\n" +
        "concept, structure the message, improve the story flow, write or refine the script, suggest\n" +
        "visual directions, and turn your rough idea into a clear production plan before we start\n" +
        "creating.",
  },
  {
    id: 5,
    q: "Can you create product explainer videos?",
    a: "Yes. We create product explainers that show what your product does, why it matters, and\n" +
        "how it helps the audience. Depending on the project, this can include scripting, storyboard\n" +
        "direction, UI visuals, motion graphics, product walkthroughs, voiceover planning, and final\n" +
        "animation.",
  },
  {
    id: 6,
    q: "What makes a good product explainer video?",
    a: "A good explainer does not just describe features. It makes the product feel useful fast. We\n" +
        "focus on the problem, the core value, the product flow, the visual clarity, and the reason\n" +
        "someone should care, so viewers can understand the offer without feeling overwhelmed.",
  },
  {
    id: 7,
    q: "Can you create launch videos for products or features?",
    a: "Yes. We create launch videos for new products, SaaS tools, apps, features, campaigns, and\n" +
        "updates. The goal is to make the launch feel exciting, clear, and premium, while giving your\n" +
        "audience a fast reason to understand, trust, and explore what you are offering.",
  },
  {
    id: 8,
    q: "Do you edit talking head videos?",
    a: "Yes. We edit founder videos, podcasts, educational content, YouTube videos, Reels,\n" +
        "Shorts, TikToks, and personal brand content. We improve pacing, structure, captions, cuts,\n" +
        "sound, motion elements, and overall watchability, so the video feels sharper and keeps\n" +
        "attention longer.",
  },
  {
    id: 9,
    q: "Can you make viral social media content?",
    a: "We create content with viral principles in mind, but we do not fake-guarantee virality. We\n" +
        "study the hook, pacing, topic angle, visual rhythm, captions, retention points, emotional\n" +
        "payoff, and platform style to give each video a much stronger chance of being watched,\n" +
        "shared, and remembered.",
  },
  {
    id: 10,
    q: "What is your creative process?",
    a: "Our process usually includes discovery, creative direction, production, feedback, revisions,\n" +
        "and final delivery. We keep the workflow clear and organized, so you always know what\n" +
        "stage the project is in and what comes next.",
  },
  {
    id: 11,
    q: "How long does the process take?",
    a: "It depends on the simplicity, length, style, and complexity of the project. Simple edits or\n" +
        "smaller visuals can take around 2 to 3 days, while product launch videos, explainers,\n" +
        "campaigns, or detailed animations can take a few weeks. After we understand the scope,\n" +
        "we give you a realistic timeline before starting",
  },
  {
    id: 12,
    q: "Do you offer revisions?",
    a: "Yes. Revisions are part of the process. After the first version, you can share feedback, and\n" +
        "we refine the work to better match your message, brand, pacing, and visual direction. The\n" +
        "number of revision rounds depends on the project scope, but our goal is always to make\n" +
        "the final result feel right.",
  },
  {
    id: 13,
    q: "Do you accept different pricing models?",
    a: "Yes. Depending on the project, we can work with fixed project pricing, package pricing,\n" +
        "monthly retainers, or ongoing creative support. Some clients need one launch video, while\n" +
        "others need consistent editing, motion graphics, ads, and social content every month. We\n" +
        "recommend the model that fits your workload and goals best.",
  },
  {
    id: 14,
    q: "Can you support ongoing monthly content?",
    a: "Yes. We can work as your ongoing creative team for video editing, social media content,\n" +
        "motion graphics, product visuals, ad creatives, and launch assets. This is useful for brands\n" +
        "that need consistent high-quality creative output without hiring a full in-house team.",
  },
  {
    id: 15,
    q: "How do we start?",
    a: "You can start in the way that is easiest for you, submit a project request on our\n" +
        "website, email us, message us on Telegram, or book a quick call. Once we receive your\n" +
        "details, we review your goals, understand the project scope, suggest the best creative\n" +
        "direction, and give you a clear next step based on your timeline, budget, and the type\n" +
        "of content you need.",
  },

];

const defaultQAById = (id: number): QAItem | undefined =>
  DEFAULT_QUESTIONS.find((q) => q.id === id);

const {
  questions: questionOverrides = DEFAULT_QUESTIONS,
  title1 = "Your Questions",
  title2 = "Answered",
  description = "Everything you need to know before starting a video, animation, or design project with\n" +
    "EyesOn Studio.",
  imageSrc = "/Shared/qa/qanda.svg",
  imageAlt = "Questions and answers illustration",
} = Astro.props as Props;

const questions: QAItem[] = questionOverrides.map((override) => {
  const def = defaultQAById(override.id);
  return {
    id: override.id,
    q: override.q ?? def?.q ?? "",
    a: override.a ?? def?.a ?? "",
  };
});
---

<section class="relative overflow-hidden px-4 py-16 text-white sm:px-6 md:px-10 md:py-24">
  <div class="relative mx-auto grid w-full max-w-7xl gap-10 lg:grid-cols-[380px_1fr] lg:gap-12 lg:items-start">
    
    {/* ===== بخش هدر و تصویر سمت چپ ===== */}
    <div class="space-y-6 sm:space-y-8 flex flex-col items-center text-center lg:items-start lg:text-left">
      <div class="w-full qa-reveal fade-up">
        <h2 class="text-3xl font-extrabold leading-tight sm:text-4xl md:text-5xl">
          <span class="block">{title1}</span>
          <span class="block text-[#39d0c3] drop-shadow-[0_0_15px_rgba(57,208,195,0.4)]">{title2}</span>
        </h2>
        <p class="mt-4 sm:mt-5 max-w-md text-[15px] leading-7 text-white/70 md:text-base mx-auto lg:mx-0 font-light">
          {description}
        </p>
      </div>

      {/* تصویر سمت چپ */}
      <div class="qa-reveal fade-up delay-100 w-full max-w-[280px] sm:max-w-[340px]">
        <SmartImage
            src={imageSrc}
            alt={imageAlt}
            width={1200}
            height={1200}
            className="select-none object-contain opacity-95 drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)] transform-gpu transition-all duration-700 ease-out hover:scale-105 hover:-translate-y-2"
        />
      </div>
    </div>

    {/* ===== بخش آکوردیون (سوالات) ===== */}
    <div class="w-full">
      <div class="space-y-3 sm:space-y-4">
        {questions.map((item, index) => (
            <div
                class={`qa-item qa-reveal fade-left overflow-hidden rounded-xl sm:rounded-2xl border bg-[#06242B] transition-all duration-500 ease-out shadow-lg hover:shadow-xl ${
                    index === 0 ? "is-open bg-[#07323B] border-cyan-400/40 shadow-[0_0_20px_rgba(57,208,195,0.1)]" : "border-cyan-400/15 hover:border-cyan-400/30 hover:bg-[#072830]"
                }`}
                style={`transition-delay: ${index * 100}ms;`}
                data-qa-index={index}
            >
              <button
                  type="button"
                  class="qa-trigger flex w-full items-start sm:items-center justify-between gap-3 sm:gap-4 px-4 py-4 sm:px-5 md:px-6 md:py-5 text-left group"
                  aria-expanded={index === 0 ? "true" : "false"}
                  aria-controls={`qa-panel-${index}`}
              >
                <span class="text-[15px] sm:text-base md:text-lg font-semibold leading-relaxed text-white/90 group-hover:text-white transition-colors duration-400 pr-2">
                  <span class="text-white/50 group-hover:text-cyan-400/80 transition-colors duration-400 mr-1">{item.id}.</span>
                  {item.q}
                </span>

                <span class="qa-icon mt-0.5 sm:mt-0 inline-flex h-6 w-6 sm:h-8 sm:w-8 shrink-0 items-center justify-center text-[#39d0c3] transition-transform duration-300 group-hover:scale-110">
                <svg class="qa-icon-plus transition-transform duration-300" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <svg class="qa-icon-close transition-transform duration-300 rotate-90" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
              </button>

              <div
                  id={`qa-panel-${index}`}
                  class={`qa-panel px-4 sm:px-5 md:px-6 ${index === 0 ? "is-open" : "is-collapsed"}`}
                  role="region"
                  aria-label={item.q}
              >
                <div class="pb-4 sm:pb-5 md:pb-6">
                  <div class="mb-4 h-px w-full bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

                  <div class="flex items-start gap-3 sm:gap-4">
                  {/* دایره A */}
                  <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-400/10 border border-cyan-400/20 text-[11px] font-bold text-cyan-400 shadow-[0_0_10px_rgba(57,208,195,0.15)]">
                    A
                  </span>
                    <p class="max-w-4xl text-[14px] sm:text-sm leading-relaxed sm:leading-7 text-white/70 font-light">
                      {item.a}
                    </p>
                  </div>
                </div>
              </div>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ================= انیمیشن‌های اسکرول ================= */
  .qa-reveal {
    opacity: 0;
    will-change: opacity, transform;
  }

  .fade-up {
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fade-left {
    transform: translateX(30px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .qa-reveal.is-visible {
    opacity: 1;
    transform: translate(0);
  }

  .delay-100 { transition-delay: 0.15s; }

  /* ================= منطق آکوردیون (CSS Grid Trick) ================= */
  .qa-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(-8px);
    transition: 
        grid-template-rows 400ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 300ms ease,
        transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .qa-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .qa-panel > div {
    overflow: hidden;
  }

  /* ================= تغییر وضعیت آیکون‌ها ================= */
  .qa-icon-plus { display: block; }
  .qa-icon-close { display: none; }

  .qa-item.is-open .qa-icon-plus { display: none; }
  .qa-item.is-open .qa-icon-close { display: block; transform: rotate(0deg); }

  .qa-trigger {
    -webkit-tap-highlight-color: transparent;
  }
</style>

<script is:inline>
  function initQA() {
    // 1. منطق انیمیشن اسکرول
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealElements = document.querySelectorAll('.qa-reveal');
    
    if (prefersReducedMotion) {
      revealElements.forEach(el => el.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      }, { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 });

      revealElements.forEach(el => observer.observe(el));
    }

    // 2. منطق آکوردیون
    const items = Array.from(document.querySelectorAll(".qa-item"));

    const setState = (item, open) => {
      const trigger = item.querySelector(".qa-trigger");
      const panel = item.querySelector(".qa-panel");
      if (!trigger || !panel) return;

      item.classList.toggle("is-open", open);
      
      // تغییر استایل دایو اصلی موقع باز شدن
      if(open) {
        item.classList.add("bg-[#07323B]", "border-cyan-400/40", "shadow-[0_0_20px_rgba(57,208,195,0.1)]");
        item.classList.remove("border-cyan-400/15");
      } else {
        item.classList.remove("bg-[#07323B]", "border-cyan-400/40", "shadow-[0_0_20px_rgba(57,208,195,0.1)]");
        item.classList.add("border-cyan-400/15");
      }

      trigger.setAttribute("aria-expanded", open ? "true" : "false");
      panel.classList.toggle("is-open", open);
      panel.classList.toggle("is-collapsed", !open);
    };

    // ریست کردن ایونت لیسنرها (برای Astro View Transitions)
    items.forEach((item) => {
      const trigger = item.querySelector(".qa-trigger");
      if (!trigger) return;
      
      // کلون کردن المنت برای حذف ایونت‌های قبلی
      const newTrigger = trigger.cloneNode(true);
      trigger.parentNode.replaceChild(newTrigger, trigger);

      newTrigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        
        // بستن بقیه
        items.forEach((other) => setState(other, false));
        
        // باز کردن آیتم کلیک شده
        if (!isOpen) {
          setState(item, true);
        }
      });
    });
  }

  // اجرا در لود اولیه و جابجایی بین صفحات در Astro
  document.addEventListener("DOMContentLoaded", initQA);
  document.addEventListener("astro:page-load", initQA);
</script>