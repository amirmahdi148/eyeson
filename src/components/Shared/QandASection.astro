---
const questions = [
  {
    id: 1,
    q: "What is motion graphics?",
    a: "Motion graphics is the art of animating graphic elements to tell stories, explain ideas, or bring branding to life. It includes animated logos, kinetic typography, and visuals used in ads, explainers, and social content.",
  },
  {
    id: 2,
    q: "Why is visual content important for my business?",
    a: "Visual content is crucial because it captures attention, conveys messages quickly, and enhances brand recognition.",
  },
  {
    id: 3,
    q: "What services do you offer?",
    a: "We offer logo animations, explainer videos, social media graphics, and more.",
  },
  {
    id: 4,
    q: "What is your production process?",
    a: "We go from concept → design → animation → delivery with full collaboration.",
  },
  {
    id: 5,
    q: "What if I don't know exactly what I want?",
    a: "That’s completely fine. We help shape the direction, define the message, and guide you through the process.",
  },
];

const QAImg = "/home/QandA.png";
---

<section class="relative overflow-hidden px-4 py-16 text-white sm:px-6 md:px-10 md:py-24">
  <div class="relative mx-auto grid w-full max-w-7xl gap-10 lg:grid-cols-[380px_1fr] lg:gap-12 lg:items-start">
    
    {/* ===== بخش هدر و تصویر سمت چپ ===== */}
    {/* 🔴 در موبایل وسط‌چین، در دسکتاپ چپ‌چین */}
    <div class="space-y-6 sm:space-y-8 flex flex-col items-center text-center lg:items-start lg:text-left">
      <div class="w-full">
        <h2 class="text-3xl font-extrabold leading-tight sm:text-4xl md:text-5xl">
          <span class="block">Your Questions</span>
          <span class="block text-[#39d0c3]">Answered</span>
        </h2>
        <p class="mt-4 sm:mt-5 max-w-md text-[15px] leading-7 text-white/70 md:text-base mx-auto lg:mx-0">
          Find answers to common questions about Eyeson and our services.
        </p>
      </div>

      {/* تصویر در موبایل‌های کوچک مخفی می‌شه، در سایزهای بزرگتر (تبلت و بالا) نشون داده میشه */}
      <img
          src={QAImg}
          alt="Questions and answers illustration"
          class="hidden w-[280px] sm:w-[320px] select-none object-contain opacity-95 md:block drop-shadow-2xl"
          loading="lazy"
          decoding="async"
      />
    </div>

    {/* ===== بخش آکوردیون (سوالات) ===== */}
    <div class="w-full">
      <div class="space-y-3 sm:space-y-4">
        {questions.map((item, index) => (
            <div
                class={`qa-item overflow-hidden rounded-xl sm:rounded-2xl border border-cyan-400/15 bg-[#06242B] transition-colors duration-300 ease-out ${
                    index === 0 ? "is-open bg-[#07323B] border-cyan-400/25" : "hover:border-cyan-400/22 hover:bg-[#072830]"
                }`}
                data-qa-index={index}
            >
              <button
                  type="button"
                  class="qa-trigger flex w-full items-start sm:items-center justify-between gap-3 sm:gap-4 px-4 py-4 sm:px-5 md:px-6 md:py-5 text-left"
                  aria-expanded={index === 0 ? "true" : "false"}
                  aria-controls={`qa-panel-${index}`}
              >
                {/* 🔴 تنظیم سایز متن و لاین‌هایت برای جلوگیری از درهم‌رفتگی در موبایل */}
                <span class="text-[15px] sm:text-base md:text-lg font-semibold leading-relaxed text-white pr-2">
                  <span class="text-white/95 mr-1">{item.id}.</span>
                  {item.q}
                </span>

                <span class="qa-icon mt-0.5 sm:mt-0 inline-flex h-6 w-6 sm:h-8 sm:w-8 shrink-0 items-center justify-center text-[#39d0c3]">
                <svg class="qa-icon-plus" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <svg class="qa-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
              </button>

              <div
                  id={`qa-panel-${index}`}
                  class={`qa-panel px-4 sm:px-5 md:px-6 ${index === 0 ? "is-open" : "is-collapsed"}`}
                  role="region"
                  aria-label={item.q}
              >
                <div class="pb-4 sm:pb-5 md:pb-6">
                  <div class="mb-3 sm:mb-4 h-px w-full bg-white/10"></div>

                  <div class="flex items-start gap-2.5 sm:gap-3">
                  {/* دایره A */}
                  <span class="mt-0.5 sm:mt-1 inline-flex h-5 w-5 sm:h-6 sm:w-6 shrink-0 items-center justify-center rounded-full bg-[#39d0c3]/15 text-[10px] sm:text-[11px] font-semibold text-[#39d0c3]">
                    A
                  </span>
                    <p class="max-w-4xl text-[14px] sm:text-sm leading-relaxed sm:leading-7 text-white/75 md:text-base">
                      {item.a}
                    </p>
                  </div>
                </div>
              </div>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* استایل‌ها تغییری نکردن، لاجیک انیمیشن درسته */
  .qa-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(-4px);
    transition:
        grid-template-rows 460ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 240ms ease,
        transform 460ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .qa-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: translateY(0);
  }

  .qa-panel > div {
    overflow: hidden;
  }

  .qa-icon-plus {
    display: block;
  }

  .qa-icon-close {
    display: none;
  }

  .qa-item.is-open .qa-icon-plus {
    display: none;
  }

  .qa-item.is-open .qa-icon-close {
    display: block;
  }

  .qa-trigger {
    -webkit-tap-highlight-color: transparent;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const items = Array.from(document.querySelectorAll(".qa-item"));

    const setState = (item, open) => {
      const trigger = item.querySelector(".qa-trigger");
      const panel = item.querySelector(".qa-panel");
      if (!trigger || !panel) return;

      item.classList.toggle("is-open", open);
      trigger.setAttribute("aria-expanded", open ? "true" : "false");
      panel.classList.toggle("is-open", open);
      panel.classList.toggle("is-collapsed", !open);
    };

    // در حالت موبایل بهتره وقتی کاربر کلیک میکنه رو اسکرول کنیم تا سوال رو ببینه
    items.forEach((item, idx) => setState(item, idx === 0));

    items.forEach((item) => {
      const trigger = item.querySelector(".qa-trigger");
      if (!trigger) return;

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        items.forEach((other) => setState(other, false));
        if (!isOpen) {
          setState(item, true);
        }
      });
    });
  });
</script>