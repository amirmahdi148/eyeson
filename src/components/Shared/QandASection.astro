---
const questions = [
  {
    id: 1,
    q: "What is motion graphics?",
    a: "Motion graphics is the art of animating graphic elements to tell stories, explain ideas, or bring branding to life. It includes animated logos, kinetic typography, and visuals used in ads, explainers, and social content.",
  },
  {
    id: 2,
    q: "Why is visual content important for my business?",
    a: "Visual content is crucial because it captures attention, conveys messages quickly, and enhances brand recognition.",
  },
  {
    id: 3,
    q: "What services do you offer?",
    a: "We offer logo animations, explainer videos, social media graphics, and more.",
  },
  {
    id: 4,
    q: "What is your production process?",
    a: "We go from concept → design → animation → delivery with full collaboration.",
  },
];

const QAImg = "/home/QandA.png";
---

<section class="relative bg-[#000E17] px-6 py-16 text-white md:px-10 md:py-24">
  <div class="mx-auto grid w-full max-w-7xl items-start gap-12 lg:grid-cols-[420px_1fr]">
    <!-- LEFT -->
    <div class="space-y-6">
      <div>
        <h2 class="text-4xl font-extrabold leading-tight md:text-5xl">
          <span class="block">Your Questions</span>
          <span class="block text-[#39d0c3]">Answered</span>
        </h2>
        <p class="mt-4 max-w-md text-sm leading-6 text-white/70 md:text-base">
          Find answers to common questions about Eyeson and our services.
        </p>
      </div>

      <img
        src={QAImg}
        alt="Q and A"
        class="hidden w-[360px] select-none object-contain opacity-90 md:block"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- RIGHT / ACCORDION -->
    <div class="w-full">
      <div class="space-y-4">
        {questions.map((item, index) => (
          <div
            class={`qa-item rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md transition-colors ${
              index === 0 ? "is-open border-white/15 bg-white/8" : "hover:border-white/15 hover:bg-white/8"
            }`}
            data-qa-index={index}
          >
            <button
              type="button"
              class="qa-trigger flex w-full items-center justify-between gap-4 px-5 py-4 text-left md:px-6 md:py-5"
              aria-expanded={index === 0 ? "true" : "false"}
              aria-controls={`qa-panel-${index}`}
            >
              <div class="flex items-center gap-3">
                <span class="qa-num inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white/85">
                  {index + 1}
                </span>
                <h3 class="text-base font-semibold leading-snug text-white md:text-lg">
                  {item.q}
                </h3>
              </div>

              <span class="qa-icon inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/8 text-white/90">
                <svg class="qa-icon-plus" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <svg class="qa-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
            </button>

            <div
              id={`qa-panel-${index}`}
              class={`qa-panel px-5 pb-4 md:px-6 md:pb-6 ${index === 0 ? "" : "is-collapsed"}`}
              role="region"
              aria-label={item.q}
            >
              <p class="text-sm leading-6 text-white/70 md:text-base">
                {item.a}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .qa-panel {
    overflow: hidden;
    max-height: 520px;
    opacity: 1;
    transition: max-height 260ms ease, opacity 220ms ease;
  }

  .qa-panel.is-collapsed {
    max-height: 0;
    opacity: 0;
    padding-bottom: 0;
  }

  .qa-icon-plus {
    display: block;
  }

  .qa-icon-close {
    display: none;
  }

  .qa-item.is-open .qa-icon-plus {
    display: none;
  }

  .qa-item.is-open .qa-icon-close {
    display: block;
  }
</style>

<!-- SCRIPT -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const items = Array.from(document.querySelectorAll(".qa-item"));

    const closeItem = (item) => {
      const trigger = item.querySelector(".qa-trigger");
      const panel = item.querySelector(".qa-panel");
      if (!trigger || !panel) return;
      item.classList.remove("is-open");
      trigger.setAttribute("aria-expanded", "false");
      panel.classList.add("is-collapsed");
    };

    const openItem = (item) => {
      const trigger = item.querySelector(".qa-trigger");
      const panel = item.querySelector(".qa-panel");
      if (!trigger || !panel) return;
      item.classList.add("is-open");
      trigger.setAttribute("aria-expanded", "true");
      panel.classList.remove("is-collapsed");
    };

    // Ensure the initial state matches markup (first item open).
    items.forEach((item, idx) => (idx === 0 ? openItem(item) : closeItem(item)));

    items.forEach((item) => {
      const trigger = item.querySelector(".qa-trigger");
      if (!trigger) return;

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        items.forEach(closeItem);
        if (!isOpen) openItem(item);
      });
    });
  });
</script>
