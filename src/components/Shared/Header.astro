---
const MENU_ITEMS = [
    { id: "1", title: "Video", path: "/video" },
    { id: "2", title: "2D/3D Animations", path: "/animation" },
    { id: "3", title: "Branding", path: "/branding" },
    { id: "4", title: "Blogs", path: "/blogs" },
];
---

<header class="fixed z-50 w-full top-0">
    <div class="relative px-4 sm:px-6 lg:px-10 max-sm:py-1.5  sm:py-2 lg:py-5">

        <!-- background -->
        <div id="header-bg" class="pointer-events-none absolute inset-x-0 top-0 h-full transition-all duration-300"></div>

        <!-- Full desktop header (your original layout) -->
        <div id="fullHeader" class="relative mx-auto max-w-[1200px] hidden lg:flex items-center justify-between gap-3">

            <!-- Logo -->
            <a href="/" class="relative z-50 max-md:invisible visible">
                <img src="/logo.png" class="h-12 sm:h-14 lg:h-[72px] object-contain" alt="EyesOn logo" />
            </a>

            <!-- Desktop menu -->
            <nav class="hidden lg:flex items-center gap-7">
                {MENU_ITEMS.map((item) => (
                        <a href={item.path} class="text-white/90 hover:text-white transition">
                            {item.title}
                        </a>
                ))}
            </nav>

            <!-- CTA -->
            <button class="hidden lg:block px-8 py-3 rounded-full text-white font-semibold bg-[#0B1F2A] border border-cyan-300/70 shadow-[0_0_50px_rgba(45,220,255,0.35)]">
                Book a Call
            </button>
        </div>

        <!-- Compact header (mobile always) -->
        <div id="compactHeaderMobile" class="relative mx-auto max-w-[1200px] flex lg:hidden items-center justify-between rounded-full border border-[#3AAFC8]/35 bg-[#03111C]/90 px-4 py-3 shadow-[0_0_28px_rgba(18,172,181,0.2)] backdrop-blur-xl sm:px-6">
            <a href="/" class="relative z-50">
                <img src="/logo.png" class="h-10 sm:h-11 object-contain" alt="EyesOn logo" />
            </a>

            <button class="rounded-full px-4 py-2 text-sm font-semibold text-white bg-linear-to-r from-[#00A9BD] to-[#1D553A] shadow-[0_0_22px_rgba(0,169,189,0.45)] sm:px-7 sm:py-2.5">
                Get free sample
            </button>

            <button class="menuBtn h-10 w-10 rounded-full border border-[#3AAFC8]/40 bg-[#07202B] flex flex-col justify-center items-center gap-1.5">
                <span class="bar w-4 h-0.5 bg-[#45D4E8]"></span>
                <span class="bar w-5 h-0.5 bg-[#45D4E8]"></span>
                <span class="bar w-4 h-0.5 bg-[#45D4E8]"></span>
            </button>
        </div>

    </div>

    <!-- MENU PANEL -->
    <div id="mobileMenu" class="fixed inset-0 z-[60] opacity-0 pointer-events-none transition">
        <div id="backdrop" class="absolute inset-0 bg-black/55"></div>

        <div id="panel" class="absolute right-0 top-0 h-screen w-[92%] max-w-[380px] border-l border-[#3AAFC8]/25 bg-[#020915] backdrop-blur-xl transform translate-x-full transition-transform duration-300">
            <div class="flex h-full flex-col px-4 pb-5 pt-6">
                <div class="mb-10 flex items-center justify-between">
                    <a href="/" class="relative z-50">
                        <img src="/logo.png" class="h-10 object-contain" alt="EyesOn logo" />
                    </a>
                    <button id="closeMenuBtn" class="h-10 w-10 rounded-full border border-[#3AAFC8]/40 bg-[#071D29] text-[#45D4E8] text-2xl leading-none">
                        ×
                    </button>
                </div>

                <div class="space-y-4 text-left text-[34px] font-semibold leading-tight text-white">
                    {MENU_ITEMS.map((item) => (
                        <a href={item.path} class="block menu-link text-lg">
                            {item.title}
                        </a>
                    ))}
                </div>

                <div class="mt-auto grid grid-cols-2 gap-3 pt-6">
                    <button class="rounded-full border border-[#3AAFC8]/45 bg-[#041827] px-3 py-3 font-semibold text-white">
                        Book a call
                    </button>
                    <button class="rounded-full bg-linear-to-r from-[#00A9BD] to-[#1D553A] px-3 py-3 font-semibold text-white shadow-[0_0_20px_rgba(0,169,189,0.35)]">
                        Get free sample
                    </button>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- SCRIPT -->
<script is:inline>
    const menuBtns = document.querySelectorAll(".menuBtn");
    const mobileMenu = document.getElementById("mobileMenu");
    const panel = document.getElementById("panel");
    const backdrop = document.getElementById("backdrop");
    const headerBg = document.getElementById("header-bg");
    const closeMenuBtn = document.getElementById("closeMenuBtn");
    const fullHeader = document.getElementById("fullHeader");
    const menuLinks = document.querySelectorAll(".menu-link");
    const desktopQuery = window.matchMedia("(min-width: 1024px)");

    let open = false;

    function setOpen(value) {
        open = value;

        if (open) {
            mobileMenu.classList.remove("opacity-0", "pointer-events-none");
            panel.classList.remove("translate-x-full");
            document.body.style.overflow = "hidden";
        } else {
            mobileMenu.classList.add("opacity-0", "pointer-events-none");
            panel.classList.add("translate-x-full");
            document.body.style.overflow = "";
        }
    }

    menuBtns.forEach((button) => button.addEventListener("click", () => setOpen(!open)));
    closeMenuBtn?.addEventListener("click", () => setOpen(false));
    backdrop?.addEventListener("click", () => setOpen(false));
    menuLinks.forEach((link) => link.addEventListener("click", () => setOpen(false)));

    function updateHeaderMode() {
        const scrolled = window.scrollY > 12;
        const isDesktop = desktopQuery.matches;

        // Desktop always uses the full header; only the background changes on scroll.
        if (isDesktop) {
            fullHeader?.classList.remove("hidden");
            fullHeader?.classList.add("lg:flex");
        }

        if (scrolled) {
            headerBg.className =
                "pointer-events-none absolute inset-x-0 top-0 h-full bg-[#061520]/85 backdrop-blur-xl  transition-all duration-300";
        } else {
            headerBg.className =
                "pointer-events-none absolute inset-x-0 top-0 h-full transition-all duration-300";
        }
    }

    window.addEventListener("scroll", updateHeaderMode, { passive: true });
    window.addEventListener("resize", updateHeaderMode);
    desktopQuery.addEventListener("change", updateHeaderMode);
    updateHeaderMode();
</script>
