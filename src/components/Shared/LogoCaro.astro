---
type Logo = { src: string; alt: string };

type Props = {
  tagline?: string;
  logos?: Logo[];
};

const {
  tagline = "Trusted by forward-thinking SaaS & AI teams worldwide",
  logos = [
    { src: "/obvi.webp", alt: "Obvi" },
    { src: "/trueclassic.webp", alt: "True Classic" },
    { src: "/obvi.webp", alt: "Obvi" },
    { src: "/trueclassic.webp", alt: "True Classic" },
    { src: "/obvi.webp", alt: "Obvi" },
    { src: "/trueclassic.webp", alt: "True Classic" },
    { src: "/obvi.webp", alt: "Obvi" },
  ],
} = Astro.props as Props;

// دو برابر کردن لوگوها برای لوپ بی‌نهایت
const loopLogos = [...logos, ...logos];
---

<section class="relative flex flex-col items-center gap-8 overflow-hidden pt-8">
  <p class="text-center text-sm tracking-wide text-white/80">{tagline}</p>

  <!-- ================= UNIFIED MARQUEE ================= -->
  <div class="logo-mask w-full px-4 opacity-80" aria-label="Brand logos">
    <div class="logo-scroll flex w-max items-center">
      {
        loopLogos.map((logo, _index) => (
          <div class="logo-slot">
            <div class="logo-item group">
              <img
                src={logo.src}
                alt={logo.alt}
                width="220"
                height="88"
                loading="lazy"
                decoding="async"
                class="logo-img h-14 md:h-20 w-full object-contain"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ================= ONLY FIX: prevent layout shift ================= */
  .logo-item {
    aspect-ratio: 220 / 88;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ================= IMAGE FIX ================= */
  .logo-img {
    opacity: 0;
    transition:
      opacity 0.35s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.3s ease;
    filter: grayscale(100%);
    will-change: opacity, transform, filter;
  }

  /* reveal after load */
  .logo-img.is-loaded {
    opacity: 0.5;
  }

  /* hover effect (بسیار نرم و جذاب) */
  .logo-item:hover .logo-img {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.08);
  }

  /* ================= MARQUEE & MASK ================= */
  .logo-mask {
    --logo-visible-count: 3; /* موبایل: 3 لوگو */
    --logo-gap: 1.25rem;
    overflow: hidden;

    /* جادوی ماسک برای هاله‌های محوشونده در دو طرف */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .logo-scroll {
    /* انیمیشن به سمت راست (مدت زمان رو میتونی کم و زیاد کنی) */
    animation: logo-scroll-right 30s linear infinite;
    will-change: transform;
  }

  /* با هاور کردن روی اسلایدر، سرعتش نصف میشه که کاربر بتونه راحت‌تر ببینه */
  .logo-scroll:hover {
    animation-play-state: paused; /* یا میتونی paused بذاری که کامل وایسته */
  }

  .logo-slot {
    flex: 0 0 calc(100vw / var(--logo-visible-count));
    padding-inline: calc(var(--logo-gap) / 2);
  }

  /* کلید حرکت به راست: شروع از -50% و پایان در 0 */
  @keyframes logo-scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  /* ================= RESPONSIVE ================= */
  @media (min-width: 640px) {
    .logo-mask {
      --logo-visible-count: 4; /* تبلت: 4 لوگو */
      --logo-gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .logo-mask {
      --logo-visible-count: 5; /* دسکتاپ: 5 لوگو */
      --logo-gap: 3rem;
      /* ماسک رو تو دسکتاپ ملایم‌تر می‌کنیم */
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
    }
  }

  /* ================= ACCESSIBILITY ================= */
  @media (prefers-reduced-motion: reduce) {
    .logo-scroll {
      animation: none;
      transform: translateX(0);
    }
  }
</style>

<script is:inline>
  // فقط برای جلوگیری از alt flash
  const imgs = document.querySelectorAll(".logo-img");

  imgs.forEach((img) => {
    const reveal = () => img.classList.add("is-loaded");

    if (img.complete) {
      reveal();
    } else {
      img.addEventListener("load", reveal);
    }
  });
</script>
