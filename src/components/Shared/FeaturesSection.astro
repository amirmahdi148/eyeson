---
import { SmartImage } from "../../utils/SmartImage";

type Props = {
  title: string;
  highlight: string;
  description: string;
};

const { title, highlight, description } = Astro.props as Props;

const features = [
  {
    id: 1,
    title: "14-Day money-back policy",
    description:
      "If your video's first cut doesn't match your expectations, you get a full refund within 14 days. No drama, no awkward explanations. Just a straightforward promise of quality and transparency.",
    path: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    bgImage: "/Branding/cardbrand.webp",
  },
  {
    id: 2,
    title: "Free sample",
    description:
      "Want to see how your footage will feel in motion? Send us a short clip and we'll create a sample edit so you can preview the pacing, style, and overall direction. Totally free, no obligations.",
    path: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    bgImage: "/Branding/cardbrand.webp",
  },
  {
    id: 3,
    title: "Scalable pricing",
    description:
      "From one-off edits to batch content, monthly packages, or ongoing support, our pricing scales with your needs. Whether you're a solo creator or a growing brand, we adapt to your workflow.",
    path: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    bgImage: "/Branding/cardbrand.webp",
  },
  {
    id: 4,
    title: "Fast turnaround",
    description:
      "Editing moves fast, and so do we. We deliver polished cuts quickly without sacrificing quality. Tight deadlines don't scare us. Your content stays fresh and lands on time.",
    path: "M13 10V3L4 14h7v7l9-11h-7z",
    bgImage: "/Branding/cardbrand.webp",
  },
  {
    id: 5,
    title: "High-quality design",
    description:
      "Strong editing is more than trimming clips. We refine pacing, visuals, audio, color, and storytelling to create clean, impactful videos that feel professional and easy to watch.",
    path: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01",
    bgImage: "/Branding/cardbrand.webp",
  },
  {
    id: 6,
    title: "5-Star reviews",
    description:
      "Clients stick with us because the results actually perform. Higher engagement, better retention, and smoother delivery. Our 5-star track record shows how polished editing transforms raw footage into high-impact content.",
    path: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    bgImage: "/Branding/cardbrand.webp",
  },
] as const;
---

<section
  class="relative w-full overflow-hidden px-6 py-20 font-sans lg:px-16"
  data-features-section
>
  <div class="relative z-10 mx-auto flex max-w-7xl flex-col items-center">
    <div class="mb-16 max-w-3xl text-center">
      <SmartImage
        src="/animation-section/Edited-Chess.webp"
        alt="Edited Chess"
        width={750}
        height={500}
        className="pointer-events-none absolute -top-20 left-1/2 h-auto w-[290px] -translate-x-1/2 -z-1 md:-top-50 md:left-auto md:right-[21%] md:w-[750px] md:translate-x-0 [mask-image:linear-gradient(to_bottom,transparent_0%,black_50%,transparent_100%),linear-gradient(to_right,transparent_0%,black_50%,transparent_100%)] [-webkit-mask-image:linear-gradient(to_bottom,transparent_0%,black_50%,transparent_100%),linear-gradient(to_right,transparent_0%,black_50%,transparent_100%)] [mask-composite:intersect] [-webkit-mask-composite:source-in]"
      />

      <h2
        class="mb-2 text-3xl leading-tight font-bold tracking-tight text-white md:text-4xl lg:text-[44px]"
      >
        {title}
      </h2>
      <h2
        class="mb-6 text-3xl font-bold tracking-tight text-[#42D1D1] md:text-4xl lg:text-[44px]"
      >
        {highlight}
      </h2>
      <p class="text-sm leading-relaxed text-gray-400 md:text-base">
        {description}
      </p>
    </div>

    <div
      class="feature-track grid w-full grid-cols-1 gap-5 md:gap-6 lg:grid-cols-3"
      data-feature-track
    >
      {
        features.map((feature, index) => (
          <article
            class="feature-card group relative min-h-70 overflow-hidden rounded-[24px] border border-white/5 bg-[#0A1A2A]/20 p-6 md:p-8 transition-all duration-300 hover:border-white/10 hover:bg-[#0A1A2A]/40 md:backdrop-blur-lg"
            data-feature-card-index={index}
          >
            {/* تصویر پس‌زمینه کارت (با شفافیت کمتر برای مینیمال شدن) */}
            <div class="absolute inset-0 z-0 mix-blend-overlay transition-opacity duration-500 ">
              <SmartImage
                src={feature.bgImage}
                fill={true}
                alt="bg"
                className="object-cover"
              />
            </div>

            {/* افکت نوری ملایم در هاور */}
            <div class="pointer-events-none absolute inset-x-0 -bottom-10 z-0 h-32 bg-gradient-to-t from-[#42D1D1]/10 to-transparent opacity-0 transition-opacity duration-500 blur-2xl group-hover:opacity-100" />

            <div class="relative z-10 flex h-full flex-col">
              {/* آیکون مینیمال شده */}
              <div class="mb-8 flex h-12 w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 shadow-sm transition-transform duration-300 group-hover:scale-105 group-hover:border-[#42D1D1]/30">
                <svg
                  class="h-5 w-5 text-white group-hover:text-[#42D1D1] transition-colors duration-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={feature.path}
                  />
                </svg>
              </div>

              {/* متون مینیمال شده */}
              <h3 class="mb-3 text-[19px] font-semibold tracking-wide text-white/95">
                {feature.title}
              </h3>
              <p class="text-[14px] leading-[1.8] font-light text-gray-400 group-hover:text-gray-300 transition-colors duration-300">
                {feature.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-6 flex items-center justify-center gap-2.5 md:hidden"
      data-feature-dots
    >
      {
        features.map((feature, index) => (
          <button
            type="button"
            class={`feature-dot h-2 w-2 rounded-full transition-all duration-300 ${index === 0 ? "is-active" : ""}`}
            aria-label={`Go to slide ${index + 1}`}
            aria-pressed={index === 0 ? "true" : "false"}
            data-feature-dot-index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  @media (max-width: 1023px) {
    .feature-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding-bottom: 1rem; /* برای جا باز کردن سایه‌ی کارت‌ها */
    }



    .feature-card {
      min-width: 85%; /* کارت‌ها تو موبایل کمی از کناره‌ها جا می‌ذارن تا کاربر بفهمه اسکرول میشه */
      scroll-snap-align: center;
    }
  }

  @media (min-width: 1024px) {
    .feature-card {
      transition: transform 300ms ease, box-shadow 300ms ease;
    }

    .feature-card:hover {
      transform: translateY(-4px);
     
    }
  }

  .feature-dot {
    background: rgba(255, 255, 255, 0.15);
  }

  .feature-dot.is-active {
    background: #42D1D1;
    width: 1.25rem; /* نقطه فعال کشیده‌تر میشه (مینیمال‌تر از رنگ پررنگ) */
  }
</style>

<script>
  const sections = document.querySelectorAll("[data-features-section]");

  sections.forEach((section) => {
    const track = section.querySelector("[data-feature-track]");
    const dotsWrap = section.querySelector("[data-feature-dots]");
    if (!(track instanceof HTMLElement) || !(dotsWrap instanceof HTMLElement))
      return;

    if (!window.matchMedia("(max-width: 1023px)").matches) return;

    const cards = Array.from(
      track.querySelectorAll("[data-feature-card-index]"),
    );
    const dots = Array.from(
      dotsWrap.querySelectorAll("[data-feature-dot-index]"),
    );
    if (cards.length === 0 || dots.length === 0) return;

    const setActive = (index: number) => {
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.setAttribute("aria-pressed", active ? "true" : "false");
        dot.classList.toggle("is-active", active);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const idx = Number(
            entry.target.getAttribute("data-feature-card-index"),
          );
          if (!Number.isNaN(idx)) setActive(idx);
        });
      },
      { root: track, threshold: 0.6 },
    );

    cards.forEach((card) => observer.observe(card));

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.getAttribute("data-feature-dot-index"));
        if (Number.isNaN(idx)) return;
        const card = track.querySelector(`[data-feature-card-index="${idx}"]`);
        if (!(card instanceof HTMLElement)) return;
        card.scrollIntoView({
          behavior: "smooth",
          inline: "center",
          block: "nearest",
        });
      });
    });
  });
</script>