---
import CaseStudyHero from "../../islands/Case/CaseStudyHero";
import CaseStudyTabsSection from "../../islands/Case/CaseStudyTabsSection";
import VisualProofSection from "../../islands/Case/VisualProofSection";
import CaseStudiesSection from "../../islands/CaseStudiesSection";
import ContactUs from "../../islands/ContactUs";
import CaseBackground from "../../islands/Case/CaseBackground";

const { slug } = Astro.props;
---

<div class="relative">
  <div class="pointer-events-none absolute inset-0">
    <CaseBackground client:load />
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(0,169,189,0.18),transparent_28%),radial-gradient(circle_at_80%_28%,rgba(0,169,189,0.18),transparent_26%),radial-gradient(circle_at_50%_115%,rgba(0,169,189,0.2),transparent_34%)]" />
    <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.15),rgba(0,0,0,0.4))]" />
    <div class="absolute inset-0 opacity-35 bg-[radial-gradient(rgba(255,255,255,0.45)_1px,transparent_1px)] bg-size-[115px_115px]" />
  </div>
  <div class="relative flex flex-col gap-3">
    <CaseStudyHero client:load slug={slug} />
    <VisualProofSection client:load />
    <CaseStudyTabsSection client:load slug={slug} />
    <CaseStudiesSection client:load />
    <ContactUs client:load />
  </div>
</div>
