---
import "./AdAssetsGrid.css";

const cards = [
  {
    title: "Static Performance Ads",
    subtitle: "Clear, bold, and conversion-focused.",
    description:
      "Static ads designed with strong visual hierarchy, sharp messaging, and scroll-stopping\n" +
        "layouts. Perfect for product promos, offer-based campaigns, feature highlights, carousels,\n" +
        "and paid social ads.",
    image: "/adcreatives/ad1.webp",
    alt: "Static Ad Creatives Examples",
  },
  {
    title: "Motion Ad Creatives",
    subtitle: "Movement built to increase retention.",
    description:
      "Animated ads that use motion, pacing, typography, and visual rhythm to hold attention\n" +
        "longer. Ideal for reels, stories, paid social, launch campaigns, and short-form promotional\n" +
        "content.",
    image: "/adcreatives/ad2.webp",
    alt: "Animated Ad Typography Example",
  },
  {
    title: "UGC Ad Editing",
    subtitle: "Real footage made more persuasive.",
    description:
      "We turn raw UGC, founder videos, testimonials, and product clips into stronger ad assets\n" +
        "with captions, hooks, motion elements, callouts, clean cuts, and platform-ready structure.",
    image: "/adcreatives/ad3.webp",
    alt: "Live-action Motion Add-ons Example",
  },
  {
    title: "Mixed Media Campaign Assets",
    subtitle: "A stronger blend of visuals, motion, and storytelling.",
    description:
      "Mixed-media ads combine footage, graphics, typography, screenshots, product visuals,\n" +
        "and motion to create memorable creatives that feel native, modern, and built for\n" +
        "engagement.",
    image: "/adcreatives/ad4.webp",
    alt: "Mixed Media Ad Creatives Example",
  },
];
---

<section class="ad-assets-section">
  <div class="ad-assets-container">
    {/* هدر بخش (Badge + Titles) */}
    <div class="ad-assets-header">
      <div class="ad-badge">
        Creative assets built for campaigns that need attention and action
      </div>
      <h2 class="ad-assets-title">
        Ad Creative Assets Built <br />
        <span class="title-highlight">to Go Viral and Convert</span>
      </h2>
      <p class="ad-assets-description">
        We create high-performing ad creatives for paid campaigns, organic social, product
        promotions, launches, and brand growth. From static visuals to animated ads and mixedmedia concepts, every asset is built to stop the scroll, make the message clear, and push
        viewers closer to clicks, leads, and sales.
      </p>
    </div>

    {/* گرید کارت‌ها */}
    <div class="ad-cards-grid">
      {
        cards.map((card) => (
          <div class="ad-card">
            <div class="ad-card-content">
              <h3 class="ad-card-title">{card.title}</h3>
              <p class="ad-card-subtitle">{card.subtitle}</p>
              <p class="ad-card-desc">{card.description}</p>
            </div>
            <div class="ad-card-image-wrapper">
              <img
                src={card.image}
                alt={card.alt}
                class="ad-card-image"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
