---
import CaseStudiesSection from "../../islands/CaseStudiesSection";
import ContactUs from "../../islands/ContactUs";
import UiUxNeed from "../../islands/Shared/UiUxNeed";
import UiUxServicesSection from "../../islands/UiUx/UiUxServicesSection";
import ApproachTimelineSection from "../../islands/Video/ApproachTimelineSection";
import CTA from "../Shared/CTA.astro";
import FeaturesSection from "../Shared/FeaturesSection.astro";
import AdCreativesSection from "./AdCreativesSection.astro";
import AdAssetsGrid from "./AdAssetsGrid.astro";
import LogoCaro from "../Shared/LogoCaro.astro";
import HighPerformingAds from "../../islands/Adcreatives/HighPerformingAds.tsx";
import AdCreativesHero from "../../islands/Adcreatives/AdCreativesHero.tsx";
import AdcreativesBackground from "../../islands/Adcreatives/AdcreativesBackground.tsx";
---

<div class="flex flex-col gap-3 justify-center items-between">
  <AdcreativesBackground client:load/>
  <AdCreativesHero client:load/>
  <AdCreativesSection />
  <FeaturesSection
    title="Excellence in High-Converting"
    highlight="Ad Creatives"
    description="We create ad creatives that do more than look polished. Every asset is built to stop the
scroll, spark engagement, communicate the offer fast, and help your campaigns convert
attention into measurable results."
    features={[
      {
        id : 1,
        title : "Scroll-Stopping Hooks",
        description : "The first second decides everything. We design ad creatives with strong visual hooks, bold\n" +
            "openings, and clear attention triggers that make people pause instead of scroll past.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 2,
        title : "Built for Virality",
        description : "We create visuals with shareability, curiosity, emotion, and platform behavior in mind,\n" +
            "giving your ads a stronger chance to get noticed, remembered, and engaged with.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 3,
        title : "Conversion Focused Design",
        description : "Every creative is structured to move viewers toward action, from clear messaging and offer\n" +
            "framing to stronger CTAs, visual hierarchy, and campaign-ready layouts.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 4,
        title : "Fast Turnaround",
        description : "Ad campaigns move fast, and so do we. We deliver polished static and motion creatives\n" +
            "quickly without sacrificing clarity, quality, or strategic thinking.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 5,
        title : "Platform Ready Creatives",
        description : "We design ads for the way people actually consume content across Instagram, TikTok,\n" +
            "YouTube, X, LinkedIn, Meta ads, landing pages, and modern digital platforms."
      },
      {
        id : 6,
        title : "Performance Driven Visuals",
        description : "Our creatives combine bold design, clean messaging, emotional triggers, and campaign\n" +
            "structure to help improve engagement, clicks, conversions, and overall ad performance.",
        bgImage : "/Shared/Features/1.png"
      },
    ]}
  />
  <UiUxNeed client:load />
  <AdAssetsGrid  />
  <UiUxServicesSection client:load />
  <HighPerformingAds client:load />
  <ApproachTimelineSection client:load />
  <CaseStudiesSection client:load />
  <ContactUs client:load />
  <CTA />
  <LogoCaro />
</div>
