---
import { BrandingHeroWrapper } from "../islands/branding/BrandingHeroWrapper";
import ContactUs from "../islands/ContactUs";
import FeaturesSection from "./Shared/FeaturesSection.astro";
import StarBackground from "../islands/StarBackground";
import { SmartImage } from "../utils/SmartImage";
import QandASection from "./Shared/QandASection.astro";
import LogoCaro from "./Shared/LogoCaro.astro";
import {WhatIsBranding} from "../islands/branding/WhatIsBranding.tsx";
import {ServicesSection} from "../islands/branding/ServicesSection.tsx";
import {AssetsGallerySection} from "../islands/branding/AssetsGallerySection.tsx";
import { WhyBrandingSection } from "../islands/branding/WhyBrandingSection";
---


<div class="relative overflow-x-clip">

    <StarBackground client:load/>
    <BrandingHeroWrapper client:load />
    <LogoCaro />
    <WhatIsBranding client:load/>
    <FeaturesSection title="Excellence in stress-free" highlight="Branding & Visual Identity" description="We don’t treat branding as decoration.  We design clear, scalable brand systems that reduce confusion, build trust, and grow with your business — without unnecessary complexity or stress."/>
    <ServicesSection client:load/>
    <AssetsGallerySection client:load/>
    <WhyBrandingSection client:load/>
    <QandASection />
    <ContactUs client:load/>
    <section class="relative z-10 mx-auto w-full max-w-7xl px-4 pb-16 sm:px-6 md:px-8 xl:px-10">
        <div class="relative overflow-hidden rounded-3xl border border-[#00A9BD]/40 shadow-[0px_0px_30px_0px_#00A9BD40]">
            <SmartImage
                    src="/blogs/Story-Back.png"
                    alt=""
                    fill={true}
                    className="object-cover"
                    sizes="(max-width: 768px) 100vw, 1200px"
            />
            <div className="absolute inset-0 bg-linear-to-r from-[#031722]/90 via-[#031722]/65 to-[#031722]/25" />

            <div class="relative flex min-h-57.5 flex-col justify-center gap-6 px-6 py-10 text-center sm:gap-8 sm:px-10 sm:text-left lg:min-h-65 lg:flex-row lg:items-center lg:justify-between lg:px-14">
                <div class="max-w-xl text-white mx-auto lg:mx-0">
                    <h2 class="text-2xl font-semibold leading-tight sm:text-3xl">
                        Let Your Story Move People.
                    </h2>
                    <p class="mt-3 text-sm text-white/85 sm:text-lg">
                        Tell us what you&apos;re building - we&apos;ll bring it to
                        life with motion.
                    </p>
                    <button class="mt-6 w-full max-w-60 mx-auto cursor-pointer rounded-xl bg-linear-to-r from-[#46B6A0] to-[#00A9BD] px-6 py-3 text-sm font-medium text-white shadow-[0_12px_30px_-10px_#00A9BD] transition sm:mx-0 sm:w-auto">
                        Start a Motion Project
                    </button>
                </div>

                <div class="relative hidden h-35 w-full max-w-70 self-end sm:block sm:h-45 sm:max-w-85 lg:h-52.5 lg:max-w-105">
                    <SmartImage
                            src="/blogs/People-ChatGPT.png"
                            alt="People discussing creative ideas"
                            width={700}
                            height={700}
                            className="object-contain object-right"
                    />
                </div>
            </div>
        </div>
    </section>
</div>
