---
import { MailboxIcon, MapPin, PhoneCall } from "lucide-react";
---

<div class="flex flex-col gap-8 md:gap-10 max-w-xs md:max-w-sm">

    <!-- logo -->
    <div class="flex justify-center md:justify-start">
        <img
                src="/logo.webp"
                alt="Logo"
                class="h-16 w-auto object-contain transition-transform duration-300 hover:scale-105"
                loading="lazy"
        />
    </div>

    <!-- headline -->
    <div class="text-lg md:text-xl font-medium text-white text-center md:text-left">
        Lets create something extraordinary together
    </div>

    <!-- contact info -->
    <div class="flex flex-col gap-3">

        <div class="flex items-center gap-3 text-white text-sm md:text-base cursor-pointer hover:text-teal-400 transition-colors duration-300">
            <PhoneCall client:load color="#46B6A0" className="min-w-6" />
            <span>+01234567890</span>
        </div>

        <div class="flex items-center gap-3 text-white text-sm md:text-base cursor-pointer hover:text-teal-400 transition-colors duration-300">
            <MailboxIcon client:load color="#46B6A0" className="min-w-6" />
            <span>eyeson.agency@gmail.com</span>
        </div>

        <div class="flex items-center gap-3 text-white text-sm md:text-base cursor-pointer hover:text-teal-400 transition-colors duration-300">
            <MapPin client:load color="#46B6A0" className="min-w-6" />
            <span>London, United Kingdom, EC2N 4AH</span>
        </div>

    </div>

</div>