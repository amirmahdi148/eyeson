---
const sections = [
    {
        title: "Design Services",
        items: ["Motion Graphics", "Brand Identity", "UI/UX Design"],
    },
    {
        title: "Animation Services",
        items: ["Motion Graphics", "2D/3D Animation", "Motion Design"],
    },
];
---

<div class="flex flex-col md:flex-row gap-8 md:gap-10 max-w-xs md:max-w-md">

    {sections.map((section) => (
            <div class="flex flex-col gap-4">

                <h2 class="text-xl md:text-2xl font-bold text-white">
                    {section.title}
                </h2>

                <ul class="flex flex-col gap-2">
                    {section.items.map((item) => (
                            <li class="cursor-pointer text-white text-sm md:text-base hover:text-[#46B6A0] transition-colors duration-300">
                                {item}
                            </li>
                    ))}
                </ul>

            </div>
    ))}

</div>