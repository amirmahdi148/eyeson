---
import { ArrowRightIcon, Youtube, Phone, Instagram } from "lucide-react";
---

<div class="flex flex-col md:flex-col gap-8 md:gap-10 max-w-xs md:max-w-sm">

    <!-- newsletter -->
    <div class="flex flex-col gap-4">

        <h2 class="text-xl font-semibold text-[#46B6A0]">
            STAY UPDATED
        </h2>

        <div class="flex bg-white/5 rounded-xl p-3 md:p-4 gap-2 items-center">

            <input
                    type="email"
                    placeholder="Your Email"
                    class="flex-1 bg-transparent border-none outline-none text-white placeholder:text-gray-400 text-sm md:text-base"
            />

            <ArrowRightIcon
                    client:load
                    className="text-white cursor-pointer hover:text-[#46B6A0] transition-colors duration-300"
                    size={24}
            />

        </div>

        <a
                href="/privacy"
                class="text-sm md:text-base underline decoration-white underline-offset-2 hover:text-[#46B6A0] transition-colors duration-300"
        >
            Privacy Policy
        </a>

    </div>

    <!-- social icons -->
    <div class="flex gap-5 justify-start">

        <Youtube
                client:load
                size={36}
                className="text-white cursor-pointer hover:text-red-500 transition-colors duration-300"
        />

        <Phone
                client:load
                size={36}
                className="text-white cursor-pointer hover:text-[#46B6A0] transition-colors duration-300"
        />

        <Instagram
                client:load
                size={36}
                className="text-white cursor-pointer hover:text-pink-500 transition-colors duration-300"
        />

    </div>

</div>