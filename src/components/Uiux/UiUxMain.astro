---
import CaseStudiesSection from "../../islands/CaseStudiesSection";
import ContactUs from "../../islands/ContactUs";
import UiUxNeed from "../../islands/Shared/UiUxNeed";
import UiUxBackground from "../../islands/UiUx/UiUxBackground";
import ApproachTimelineSection from "../../islands/Video/ApproachTimelineSection";
import CTA from "../Shared/CTA.astro";
import UiUxHeroSection from "../../islands/UiUx/UiUxHeroSection";
import LogoCaro from "../Shared/LogoCaro.astro";
import FeaturesSection from "../Shared/FeaturesSection.astro";
import UiUxServicesSection from "../../islands/UiUx/UiUxServicesSection";
import UiUxExcellenceSection from "./UiUxExcellenceSection.astro";
import UiUxPricingSlider from "../../islands/UiUx/UiUxPricingSlider";
import UiUxAppSlider from "../../islands/UiUx/UiUxAppSlider"; 
---

<div class="flex flex-col gap-3 justify-center items-between">
  <UiUxBackground client:load />
  <UiUxHeroSection client:load />
  <LogoCaro />
  <FeaturesSection
    title="Excellence in stress-free"
    highlight="Branding & Visual Identity"
    description="We don't treat branding as decoration. We design clear, scalable brand systems that reduce confusion, build trust, and grow with your business — without unnecessary complexity or stress."
  />
  <UiUxServicesSection client:load />
  <UiUxNeed client:load />
  <UiUxExcellenceSection client:load />
  <ApproachTimelineSection client:load />
  <CaseStudiesSection client:load />
  <UiUxAppSlider client:load />
  <UiUxPricingSlider client:load />
  <ContactUs client:load />
  <CTA client:load />
</div>
