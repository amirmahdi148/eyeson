---
import CaseStudiesSection from "../../islands/CaseStudiesSection";
import ContactUs from "../../islands/ContactUs";
import UiUxNeed from "../../islands/Shared/UiUxNeed";
import UiUxBackground from "../../islands/UiUx/UiUxBackground";
import ApproachTimelineSection from "../../islands/Video/ApproachTimelineSection";
import CTA from "../Shared/CTA.astro";
import UiUxHeroSection from "../../islands/UiUx/UiUxHeroSection";
import LogoCaro from "../Shared/LogoCaro.astro";
import FeaturesSection from "../Shared/FeaturesSection.astro";
import UiUxServicesSection from "../../islands/UiUx/UiUxServicesSection";
import UiUxExcellenceSection from "./UiUxExcellenceSection.astro";
import UiUxPricingSlider from "../../islands/UiUx/UiUxPricingSlider";
import UiUxAppSlider from "../../islands/UiUx/UiUxAppSlider";
import { SplineScene } from "@/islands/About/SplineAboutPage";
import PrimaryButton from "../Shared/PrimaryButton";

const features = [
  {
    id : 1,
    title : "User First Approach",
    description : "Every design decision is made with real users in mind, creating experiences that feel\n" +
        "natural and easy to navigate.",
    bgImage : "/Shared/Features/1.png"
  },
  {
    id : 2,
    title : "SaaS & Product Focused",
    description : "From startups to growing platforms, we design interfaces tailored for modern SaaS and\n" +
        "digital products.",
    bgImage : "/Shared/Features/1.png"
  },
  {
    id : 3,
    title : "Built for Scalability",
    description : "Design systems and interfaces structured to grow with your product and team.",
    bgImage : "/Shared/Features/1.png"
  },
  {
    id : 4,
    title : "Conversion Focused",
    description : "Landing pages and user flows designed to guide visitors toward meaningful actions.",
    bgImage : "/Shared/Features/1.png"
  },
  {
    id : 5,
    title : "Clean & Intuitive Design",
    description : "Modern interfaces that simplify complex information and improve usability."
  },
  {
    id : 6,
    title : "Collaborative Process",
    description : "Transparent communication, structured feedback, and a streamlined workflow from\n" +
        "concept to delivery.",
    bgImage : "/Shared/Features/1.png"
  },
]

---

<div class="flex flex-col gap-3 justify-center items-between">
  <UiUxBackground client:load />
  <UiUxHeroSection client:load />
  <LogoCaro />

  <section class="relative w-full overflow-hidden py-12 md:py-16 lg:py-24">
    <div
      class="mx-auto flex w-full max-w-7xl flex-col items-center gap-8 px-4 sm:px-6 lg:flex-row lg:justify-between lg:gap-12 lg:px-8"
    >

      <div
        class="order-1 lg:order-2 relative flex w-full items-center justify-center h-87.5 sm:h-112.5 lg:h-137.5 lg:w-[55%] xl:w-[60%]"
      >
        <SplineScene
          scene="https://prod.spline.design/kZDDjO5HuC9GJUM2/scene.splinecode"
          className="w-full h-full object-contain"
          client:load
        />
      </div>


      <div
        class="order-2 lg:order-1 relative z-10 flex w-full flex-col items-center text-center lg:w-[45%] xl:w-[40%] lg:items-start lg:text-left gap-6 lg:gap-8"
      >
        <div>
          <h1
            class="text-center text-3xl sm:text-4xl md:text-5xl lg:text-[42px] xl:text-5xl font-black bg-clip-text text-transparent bg-linear-to-b from-neutral-50 to-neutral-400 leading-[1.15]"
          >
            What is <span class="text-[#31B9C4]">UI/UX design?</span>
          </h1>
          <p
            class="mt-4 sm:mt-6 text-[14px] sm:text-base lg:text-lg leading-relaxed text-neutral-300 max-w-lg mx-auto lg:mx-0 font-light"
          >
            UI/UX design is the process of designing the interface and user experience of a digital
            product. It focuses on how your website, app, or platform looks, feels, and functions for the
            people using it.
            Good UI/UX makes navigation intuitive, information easy to understand, and every
            interaction seamless. Whether it's a website, landing page, SaaS platform, or mobile app,
            great design helps users accomplish their goals faster and with less friction.
          </p>
        </div>


        <PrimaryButton text="See our Work" width="60%" />
      </div>
    </div>
  </section>

  <FeaturesSection
    title="Why Teams Choose EyesOn for"
    highlight="UI/UX design"
    description="We combine strategy, usability, and modern design to create digital experiences that look
great, feel intuitive, and support long term product growth."
    features={features}
  />
  <UiUxServicesSection client:load />
  <UiUxNeed client:load />
  <UiUxExcellenceSection />
  <ApproachTimelineSection client:load />
  <UiUxAppSlider client:load />
  <CaseStudiesSection client:load />

  <UiUxPricingSlider client:load />
  <ContactUs client:load />
  <CTA />
</div>
