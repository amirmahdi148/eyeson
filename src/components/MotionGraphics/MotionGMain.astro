---
import { HeroBasic } from "@/islands/Shared/HeroBasic";
import WhatMGAre from "@/components/MotionGraphics/WhatMGAre.astro";
import FeaturesSection from "@/components/Shared/FeaturesSection.astro";
import WhatWeCreate from "@/components/MotionGraphics/WhatWeCreate.astro";
import MotionSection from "@/islands/MotionGraphics/FolderSection";
import { BusinessNeedsWrapper } from "@/islands/MotionGraphics/BusinessNeedsWrapper.tsx";
import { MotionGraphicsSection } from "@/islands/MotionGraphics/WhyUs";
import CustomerStoriesShowcase from "@/components/Portfolio/CustomerStoriesShowcase.astro";
import CaseStudiesSection from "@/islands/CaseStudiesSection";
import CostVideo from "@/components/Shared/CostVideo.astro";
import QandASection from "@/components/Shared/QandASection.astro";
import CTA from "../Shared/CTA.astro";
import HomeBackground from "@/components/Home/HomeBackground.astro";
---

<div class="min-h-screen">
  <HomeBackground />
  <HeroBasic
    client:load
    BeforeHighlight="Motion Graphics That Make"
    Highlight="Complex Ideas Feel Simple."
    Description="We create motion graphics that explain products, simplify messages, and turn brand ideas
into clear, engaging visual stories built for modern digital platforms."
    imageUrl="/motion-graphics/hero-motion.webp"
    primaryBtnText="Start a Project"
    primaryBtnUrl="/contact"
    secondaryBtnUrl="/pricing"
    secondaryBtnText="Get Pricing"
    imageDivClassName="relative lg:!max-w-none lg:w-[140%] lg:-ml-40 lg:mt-0 mt-10 z-0 hidden  lg:block"
    imageWrapperClassName="absolute w-170 h-230 -right-10 top-50"
    imageClassName="w-130 h-230 object-contain drop-shadow-[0_0_50px_rgba(50,210,199,0.15)]"
    textContainerClassName="relative z-10 "
    headingClassName="!text-white text-[24px] md:text-[27px] lg:text-[32px] font-bold tracking-tight leading-[1.1]"
    highlightClassName="!text-[#2fd0c8] !bg-none font-bold"
    descriptionClassName="!text-white/60 max-w-lg text-sm md:text-base leading-relaxed "
    primaryBtnWrapperClassName="hover:scale-105 transition-transform duration-300"
    primaryBtnClassName="!bg-[#2fd0c8] text-white font-bold !px-10 !py-3.5 shadow-[0_0_30px_rgba(47,208,200,0.5)]"
    secondaryBtnWrapperClassName="hover:scale-105 transition-transform duration-300"
    secondaryBtnClassName="!bg-transparent !border-2 !border-[#2fd0c8] !text-white font-bold !px-10 !py-3.5 shadow-[0_0_20px_rgba(47,208,200,0.2)]"
    showBackground={true}
    sectionClassName="!mt-0  pb-20"
  />

  <WhatMGAre />
  <FeaturesSection
    title="Excellence in stress-free"
    highlight="Motion Graphics Production"
    description="We make the motion graphics process clear, organized, and easy to manage, from first idea
to final export, so you get polished visuals without messy communication or production
stress."
    features={[
      {
        id : 1,
        title : "Clear Creative Direction",
        description : "We start every project by understanding your goal, audience, message, and visual style, so\n" +
            "the animation has a clear purpose before production begins.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 2,
        title : "Preview Before Full Production",
        description : "Before the final animation is built, we align on the direction, pacing, structure, and visual\n" +
            "approach, helping you avoid confusion, wasted time, and unnecessary revisions.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 3,
        title : "Flexible Project Scope",
        description : "From short motion assets to full explainers, launch visuals, and ongoing content packages,\n" +
            "our workflow adapts to your timeline, budget, and production needs.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 4,
        title : "Fast Turnaround",
        description : "Motion projects need momentum. We keep the process efficient with clear milestones,\n" +
            "organized feedback, and focused production timelines without sacrificing quality.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 5,
        title : "High Quality Motion Design",
        description : "We focus on smooth animation, strong composition, clean transitions, visual rhythm,\n" +
            "sound, and storytelling to make every motion graphic feel polished and professional.",
        bgImage : "/Shared/Features/1.png"
      },
      {
        id : 6,
        title : "Reliable Communication",
        description : "No confusing process or disappearing creatives. You get clear updates, structured\n" +
            "feedback rounds, and a production flow designed to keep your project moving smoothly.",
        bgImage : "/Shared/Features/1.png"
      },
    ]}
  />
  <WhatWeCreate />
  <BusinessNeedsWrapper client:load />
  <MotionGraphicsSection client:only="react" />
  <MotionSection client:load />
  <CaseStudiesSection client:load />
  <CostVideo />
  <QandASection />
  <CTA />
</div>

<style is:global>
  .motion-div {
    will-change: transform, opacity;
    backface-visibility: hidden;
  }
  .rounded-full {
    border-radius: 9999px !important;
  }

  h2 {
    font-family: "Inter", sans-serif;
  }
  section {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-wrap: balance;
  }

  /* Performance optimization for hover transitions */
  article {
    will-change: transform, border-color, box-shadow;
  }
</style>
