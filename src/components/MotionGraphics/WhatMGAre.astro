---
import { SmartImage } from "@/utils/SmartImage";
---

<div class="relative py-16 sm:py-24 lg:py-32 overflow-hidden">
  <div class="absolute top-1/4 -right-20 w-[500px] h-[500px] -z-10"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-x-16 gap-y-12 lg:grid-cols-2">
      <!-- Left Column: Image — top on mobile -->
      <div class="relative order-1 lg:order-1">
        <div class="relative group">
          <SmartImage
            src="/motion-graphics/boh.webp"
            alt="Motion Graphics Production Interface"
            className="w-full h-auto rounded-2xl drop-shadow-[0_20px_50px_rgba(0,0,0,0.9)] transition-transform duration-500 group-hover:scale-[1.01]"
          />
          <div
            class="absolute inset-0 -z-10 bg-[#2fd0c8]/10 blur-3xl rounded-full scale-90 opacity-50"
          >
          </div>
        </div>
      </div>

      <!-- Right Column: Text — bottom on mobile -->
      <div class="order-2 lg:order-2 text-center lg:text-left">
        <h2
          class="text-lg md:text-2xl lg:text-[28px] font-black tracking-tight text-white leading-[1.1]"
        >
          What <span class="text-[#2fd0c8]">Motion Graphics</span> Are and Why Your
          Brand Needs Them
        </h2>

        <div class="mt-6 space-y-4">
          <p class="text-sm leading-relaxed text-white/70 font-medium">
            Motion graphics turn static information into visual stories that are easier to understand,
            easier to remember, and more engaging to watch.
            Instead of relying on plain images, long explanations, or complicated screenshots, motion
            helps your audience quickly understand what matters. It brings rhythm, structure, and
            visual clarity to your message, making your brand feel more modern, professional, and
            easier to trust.
            For SaaS products, AI tools, startups, content teams, and modern brands, motion graphics
            help explain value faster, improve content retention, and make every message feel sharper
            across websites, social media, launch videos, ads, and presentations.
          </p>
        </div>

        <div class="mt-8 flex justify-center lg:justify-start">
          <a
            href="/portfolio"
            class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-[#00A9BD] to-[#124d43] px-8 py-3 text-sm font-bold text-white shadow-[0_0_25px_rgba(0,169,189,0.5)] transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(0,169,189,0.7)]"
          >
            See our work
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
