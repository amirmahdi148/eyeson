---


interface Props {
  titleLine1?: string;
  titleLine2?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  imageUrl?: string;
}

const {
  titleLine1 = "We turn raw ideas into",
  titleLine2 = "powerful creative directions",
  description = "Our team specializes in shaping your thoughts into clear, strategic concepts that actually move people. From brainstorming narrative styles to defining visual worlds, we craft ideas that become the foundation of strong motion design, animation, and product-focused storytelling.",
  buttonText = "See our work",
  buttonLink = "#work",
  imageUrl = "/home/home-frame.png",
} = Astro.props;
---

<section class="relative w-full overflow-hidden py-16 md:py-24 lg:py-32">
  <div class="relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16 xl:gap-24">

      {/* تصویر */}
      <div class="w-full lg:w-[55%] flex justify-center lg:justify-start">
        <div class="relative w-full max-w-[600px]">
          <div class="relative z-10 w-full transform-gpu transition-transform duration-500 hover:scale-[1.02]">
            <img
                src={imageUrl}
                alt="Creative Directions Concept"
                class="w-full h-auto object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)]"
                loading="lazy"
            />
          </div>
        </div>
      </div>

      {/* متن */}
      <div class="w-full lg:w-fit flex flex-col items-center text-center lg:items-start lg:text-start">
        <h2 class="text-[32px] sm:text-[30px] lg:text-[42px] font-extrabold leading-[1.15] tracking-tight mb-6">
          <span class="block text-white mb-1">{titleLine1}</span>
          <span class="block bg-gradient-to-r from-[#29C4A9] to-[#128a8a] bg-clip-text text-transparent">
            {titleLine2}
          </span>
        </h2>

        <p class="text-[15px] sm:text-[16px] leading-[1.7] text-white/60 max-w-[48ch] mb-10 font-light">
          {description}
        </p>

        <div class="relative group">
          <div class="absolute -inset-[2px] rounded-full bg-gradient-to-r from-[#1AA19C] to-[#0A4F53] blur-[10px] opacity-60 group-hover:opacity-100 transition-opacity duration-300"></div>

          <a
              href={buttonLink}
              class="relative flex items-center justify-center px-12 py-2.5 rounded-full bg-gradient-to-r from-[#179B89] to-[#0D5F63] text-white font-bold text-[15px] transition-transform duration-300 group-hover:scale-[1.02] shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"
          >
            {buttonText}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>