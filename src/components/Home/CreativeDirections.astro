---
import { SmartImage } from "@/utils/SmartImage";
import PrimaryButton from "../Shared/PrimaryButton";

// CreativeDirections.astro

interface Props {
  titleLine1?: string;
  titleLine2?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  imageUrl?: string;
}

const {
  titleLine1 = "We turn raw ideas into",
  titleLine2 = "powerful creative directions",
  description = "Our team specializes in shaping your thoughts into clear, strategic concepts that actually move people. From brainstorming narrative styles to defining visual worlds, we craft ideas that become the foundation of strong motion design, animation, and product-focused storytelling.",
  buttonText = "See our work",
  buttonLink = "#work",
  imageUrl = "/home/home-frame.png",
} = Astro.props;
---

<section class="relative w-full overflow-hidden  ">
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 lg:px-8">
    <div
      class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8 xl:gap-12"
    >
      {/* Image Section: Now comes first in the DOM for mobile top-alignment */}
      <div
        class="w-full lg:w-[55%] flex justify-center lg:justify-start order-1 lg:order-1 mx-auto"
      >
        <div
          class="relative w-full max-w-[500px]"
        >
          {/* Increased height and scale for a more prominent look */}
          <div
            class="relative z-10 w-full transform-gpu transition-transform duration-500 hover:scale-[1.05] min-h-[300px] sm:min-h-[450px] flex items-center justify-center mx-auto"
          >
            <SmartImage
              src={imageUrl}
              alt="Creative Directions Concept"
              className="w-full h-auto object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)] scale-100 lg:scale-100"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      {/* Text Content Section */}
      <div
        class="w-full lg:w-[45%] flex flex-col items-center text-center lg:items-start lg:text-left order-2 lg:order-2"
      >
        {/* Adjusted Font Sizes: Smaller than previous version */}
        <h2
          class="text-[28px] sm:text-[34px] lg:text-[42px] font-extrabold leading-[1.15] tracking-tight mb-4 sm:mb-6"
        >
          <span class="block text-white mb-1">{titleLine1}</span>
          <span
            class="block bg-gradient-to-r from-[#29C4A9] to-[#128a8a] bg-clip-text text-transparent"
          >
            {titleLine2}
          </span>
        </h2>

        {/* Adjusted Description Font Size */}
        <p
          class="text-[14px] sm:text-[15px] leading-[1.6] text-white/60 max-w-[48ch] mx-auto lg:mx-0 mb-8 sm:mb-10 font-light"
        >
          {description}
        </p>

        {/* Button Section: Centered on mobile via items-center on parent */}
        <div class="relative group w-full sm:w-auto">
          <PrimaryButton text={buttonText} width="14rem" />
        </div>
      </div>
    </div>
  </div>
</section>
