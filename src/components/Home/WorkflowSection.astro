---

interface CardItem {
  title: string;
  description: string;
  buttonText: string;
  imageUrl: string;
}

interface Props {
  headingTop?: string;
  headingBottom?: string;
  description?: string;
  cards?: CardItem[];
}

const {
  headingTop = "Powerful systems",
  headingBottom = "for an effective workflow",
  description = "Our workflow is built to be fast, clear and stress-free. Whether you want full creative involvement or prefer a hands-off approach, our process adapts to how you like to work. As we've expanded our services, our system has evolved too, but one thing never changes: every project starts with a sample.",
  cards = [
    {
      title: "Free sample",
      description:
        "Experience our work before committing. We start every project with a free sample so you can see our style, quality and process firsthand. It helps you confirm we're the right fit before anything moves forward.",
      buttonText: "Try our service for free",
      imageUrl: "./home/frame1.png",
    },
    {
      title: "Planning & collaboration",
      description:
        "Here we work with you to develop a clear storyboard and a detailed production plan tailored to your video. This stage keeps everyone aligned and ensures the concept is solid before production begins.",
      buttonText: "Project planning",
      imageUrl: "./home/frame2.png",
    },
    {
      title: "Final delivery",
      description:
        "When the storyboard is approved, we begin full production. Throughout the process, we stay in touch to make sure the final video matches your expectations and delivers exactly what your brand needs.",
      buttonText: "Swift & easy access",
      imageUrl: "./home/frame3.png",
    },
  ],
} = Astro.props;
---

<section class="relative overflow-hidden py-16 sm:py-20 lg:py-28">

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-black leading-tight tracking-tight sm:text-4xl lg:text-[2.8rem]">
        <span class="block bg-gradient-to-r from-[#2fd0c8] to-[#60d6c6] bg-clip-text text-transparent">
          {headingTop}
        </span>
        <span class="mt-1 block text-white">
          {headingBottom}
        </span>
      </h2>

      <p class="mt-6 text-sm leading-7 text-white/60 sm:text-[15px]">
        {description}
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 md:grid-cols-3">
      {cards.map((card, index) => (
        <article
          class="group relative flex h-full flex-col overflow-hidden rounded-[26px] border border-[#0f2931] bg-[#051821]/95 p-5 shadow-[0_18px_45px_rgba(0,0,0,0.65)] backdrop-blur-md transition-all duration-300 ease-out
                 hover:-translate-y-2 hover:border-[#33d2c7] hover:shadow-[0_0_0_1px_rgba(51,210,199,0.6),0_24px_70px_rgba(0,0,0,0.85)]"
        >
        
          <div class="pointer-events-none absolute inset-0 rounded-[26px] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute inset-[1px] rounded-[24px] border border-[#33d2c7]/70" />
          </div>


          <div class="relative mb-6 overflow-hidden rounded-[18px] border border-[#12323b] bg-[#0b222a]">
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-cyan-400/10 via-transparent to-transparent" />
            <img
              src={card.imageUrl}
              alt={card.title}
              loading="lazy"
              width="900"
              height="560"
              class="block h-auto w-full object-cover"
            />
          </div>

         
          <div class="flex flex-1 flex-col">
            <h3 class="text-[1.4rem] font-extrabold text-white sm:text-[1.55rem]">
              {card.title}
            </h3>

            <p class="mt-3 text-sm leading-7 text-white/65 sm:text-[15px]">
              {card.description}
            </p>

       
            <div class="mt-7 flex justify-center">
              <button
                type="button"
                class="inline-flex min-h-11 items-center justify-center rounded-full bg-gradient-to-r from-[#21c2cf] to-[#71d3b7] px-6 py-2.5 text-sm font-semibold text-[#032024] shadow-[0_0_22px_rgba(44,211,199,0.35)] transition-transform duration-200 group-hover:scale-[1.01]"
              >
                {card.buttonText}
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>