---
interface CardItem {
  title: string;
  description: string;
  buttonText: string;
  imageUrl: string;
}

interface Props {
  headingTop?: string;
  headingBottom?: string;
  description?: string;
  cards?: CardItem[];
}

const {
  headingTop = "Powerful systems",
  headingBottom = "for an effective workflow",
  description = "Our workflow is built to be fast, clear and stress-free.",
  cards = [
    {
      title: "Discovery & Strategy",
      description: "We dive deep into your brand, understanding your goals and audience to craft a tailored creative strategy.",
      buttonText: "Learn more",
      imageUrl: "/home/home-frame.png"
    },
    {
      title: "Concept & Storyboarding",
      description: "Translating strategies into visual stories. We storyboard every frame to ensure the narrative flows perfectly.",
      buttonText: "View process",
      imageUrl: "/home/eyes-home.png"
    },
    {
      title: "Design & Animation",
      description: "Bringing ideas to life with high-end motion design, fluid animations, and stunning UI/UX deliverables.",
      buttonText: "See examples",
      imageUrl: "/home/home-frame.png"
    },
    {
      title: "Delivery & Scaling",
      description: "Final polish, rendering, and delivery across all required formats, ready to scale your marketing efforts.",
      buttonText: "Get started",
      imageUrl: "/home/eyes-home.png"
    }
  ],
} = Astro.props;
---

<section class="relative overflow-hidden py-16 sm:py-24 lg:py-32">
  

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      
      <h2 class="workflow-reveal fade-up delay-100 text-3xl font-black leading-tight tracking-tight sm:text-4xl lg:text-[3.2rem]">
        <span class="block bg-gradient-to-r from-[#2fd0c8] via-[#60d6c6] to-[#2fd0c8] bg-[length:200%_auto] animate-gradient bg-clip-text text-transparent pb-1">
          {headingTop}
        </span>
        <span class="mt-1 block text-white drop-shadow-md">
          {headingBottom}
        </span>
      </h2>

      <p class="workflow-reveal fade-up delay-200 mt-6 text-sm leading-relaxed text-white/60 sm:text-base font-light max-w-2xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Swiper Container -->
    <div class="mt-16 workflow-reveal fade-up delay-300">
      <swiper-container init="false" class="mySwiper !pb-16">
        {cards.map((card) => (
          <swiper-slide class="h-auto">
            <article
              class="group relative flex h-full flex-col overflow-hidden rounded-[24px] border border-[#0f2931] bg-gradient-to-b from-[#051821]/95 to-[#020a0f]/95 p-5 shadow-[0_18px_45px_rgba(0,0,0,0.4)] backdrop-blur-xl transform-gpu transition-all duration-500 ease-out  hover:border-[#33d2c7]/50 hover:shadow-[0_0_30px_rgba(51,210,199,0.15),0_24px_70px_rgba(0,0,0,0.6)]"
            >
              <!-- Hover Border Glow Effect -->
              <div class="pointer-events-none absolute inset-0 rounded-[24px] opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <div class="absolute inset-[1px] rounded-[22px] border border-[#33d2c7]/50" />
                <div class="absolute top-0 inset-x-0 h-32 bg-gradient-to-b from-[#33d2c7]/10 to-transparent rounded-t-[22px]" />
              </div>

              <!-- عکس کارت با افکت زوم نرم -->
              <div class="relative mb-6 overflow-hidden rounded-[16px] border border-[#12323b] bg-[#0b222a]">
                <img
                  src={card.imageUrl}
                  alt={card.title}
                  loading="lazy"
                  class="block h-52 sm:h-64 w-full object-cover transform-gpu transition-transform duration-700 group-hover:scale-105"
                />
                {/* هاله تاریک پایین عکس برای خوانایی بهتر مرزها */}
                <div class="absolute inset-0 bg-gradient-to-t from-[#051821] to-transparent opacity-60"></div>
              </div>

              <div class="flex flex-1 flex-col z-10">
                <h3 class="text-xl font-extrabold text-white transition-colors group-hover:text-[#33d2c7]">
                  {card.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-white/65 font-light flex-grow">
                  {card.description}
                </p>
                
                {/* دکمه با افکت پرش به بالا در هاور کارت */}
                <div class="mt-8 flex justify-start transform transition-transform duration-500 group-hover:-translate-y-1">
                  <button class="inline-flex min-h-10 items-center justify-center rounded-xl bg-white/5 border border-white/10 px-6 py-2.5 text-sm font-semibold text-white transition-all duration-300 hover:bg-[#33d2c7] hover:text-[#032024] hover:border-transparent hover:shadow-[0_0_20px_rgba(51,210,199,0.4)] w-full sm:w-auto">
                    {card.buttonText}
                  </button>
                </div>
              </div>
            </article>
          </swiper-slide>
        ))}
      </swiper-container>
    </div>
  </div>
</section>

<style>
  /* ================= Gradient Text Animation ================= */
  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .animate-gradient {
    animation: gradient 8s ease infinite;
  }

  /* ================= Scroll Reveal Animations ================= */
  .workflow-reveal {
    opacity: 0;
    will-change: opacity, transform;
  }

  .fade-up {
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .workflow-reveal.is-visible {
    opacity: 1;
    transform: translate(0);
  }

  /* Stagger Delays */
  .delay-100 { transition-delay: 0.1s; }
  .delay-200 { transition-delay: 0.2s; }
  .delay-300 { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .workflow-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ================= Swiper Customization ================= */
  swiper-container::part(bullet-active) {
    background: #33d2c7;
    width: 24px;
    border-radius: 4px;
    transition: width 0.3s ease;
  }
  swiper-container::part(bullet) {
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
    transition: background 0.3s ease, width 0.3s ease;
  }
  swiper-container::part(bullet):hover {
    background: rgba(255, 255, 255, 0.5);
  }

  swiper-slide {
    height: auto !important;
    display: flex;
  }
</style>

<script>
  import { register } from 'swiper/element/bundle';
  
  // Initialize Scroll Animations
  function initWorkflowAnimations() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const elements = document.querySelectorAll('.workflow-reveal');
    
    if (prefersReducedMotion) {
      elements.forEach(el => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 });

    elements.forEach(el => observer.observe(el));
  }

  // Initialize Swiper
  function initSwiper() {
    register();
    const swiperEl = document.querySelector('swiper-container.mySwiper');
    if (swiperEl) {
      const swiperParams = {
        slidesPerView: 1.1,
        spaceBetween: 20,
        centeredSlides: false,
        grabCursor: true,
        pagination: {
          clickable: true,
          dynamicBullets: true,
        },
        breakpoints: {
          640: {
            slidesPerView: 2.1,
            spaceBetween: 24,
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 32,
            allowTouchMove: true, // تغییر دادم به true که تو دسکتاپ هم بشه درگ کرد (تجربه کاربری بهتر)
          },
        },
      };
      Object.assign(swiperEl, swiperParams);
      (swiperEl as any).initialize();
    }
  }

  // Run on load and after Astro view transitions
  document.addEventListener('DOMContentLoaded', () => {
    initSwiper();
    initWorkflowAnimations();
  });
  
  document.addEventListener('astro:page-load', () => {
    initSwiper();
    initWorkflowAnimations();
  });
</script>