---
interface Props {
  eyebrow?: string;
  title?: string;
  highlight?: string;
  description?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  eyebrow = "Why choose us",
  title = "A full animation and design team for less than one hire",
  highlight = "",
  description = "With eyeson, you don’t just get great visuals. You get a dedicated group of motion designers, animators and UI specialists who work together every day to deliver consistent, high-quality creative output. It's the fastest way to scale your visuals without the cost or hassle of building an in-house team.",
  primaryText = "Book a quick call",
  primaryHref = "#",
  secondaryText = "Learn more",
  secondaryHref = "#",
} = Astro.props;
---

<section class="relative overflow-hidden py-16 sm:py-20 lg:py-28">


  <div
    class="relative mx-auto flex w-full max-w-7xl flex-col items-center gap-12 px-4 sm:px-6 lg:flex-row lg:gap-16 lg:px-8"
  >
    <div class="w-full lg:w-[48%]">
      <div
        class="mb-5 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 shadow-[0_0_0_1px_rgba(0,0,0,0.15)] backdrop-blur-sm"
        style="background: radial-gradient(56.08% 159.18% at 29.68% 91.67%, #11565F 0%, #0B1F2A 100%) /* warning: gradient uses a rotation that is not supported by CSS and may not behave as expected */;
"
      >
        <span
          class="h-3 w-3 rounded-full bg-cyan-400 shadow-[0_0_18px_rgba(34,211,238,0.85)]"
        ></span>
        <span class="text-sm text-white/75">{eyebrow}</span>
      </div>

      <h2
        class="max-w-xl text-3xl font-black leading-[1.08] tracking-tight text-white sm:text-4xl lg:text-[3.35rem]"
      >
        {title}
        {highlight && <span class="block text-cyan-300">{highlight}</span>}
      </h2>

      <p class="mt-6 max-w-xl text-sm leading-7 text-white/65 sm:text-[15px]">
        {description}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={primaryHref}
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-gradient-to-r from-cyan-400 to-emerald-400 px-7 py-3 text-sm font-semibold text-[#031016] shadow-[0_0_24px_rgba(34,211,238,0.45)] transition-transform duration-200 hover:scale-[1.02]"
        >
          {primaryText}
        </a>

        <a
          href={secondaryHref}
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-cyan-400/35 bg-[#091E2A] px-7 py-3 text-sm font-semibold text-white shadow-[0_0_22px_rgba(34,211,238,0.18)] transition-colors duration-200 hover:border-cyan-300/60 hover:bg-[#0a1d26]"
        >
          {secondaryText}
        </a>
      </div>
    </div>

    <div class="w-full lg:w-[52%]">
      <div class="relative mx-auto w-full max-w-[620px]">
        <div class="absolute inset-0"></div>
        <div class="relative overflow-hidden">
          <img
            src="./home/eyes-home.png"
            alt="Why choose us visual"
            class="block h-auto w-full object-cover"
            loading="lazy"
            width="1200"
            height="900"
          />
        </div>
      </div>
    </div>
  </div>
</section>
