---
import { CheckCircle } from "lucide-react";
import { SmartImage } from "@/utils/SmartImage.tsx";

const data = [
  { title: "Strategy-first scripting" },
  { title: "UI-native motion design" },
  { title: "Built specially for SaaS" },
  { title: "Clarity over flashy effects" },
];
---

<div class="w-full flex items-center justify-center px-4 py-10 scale-110">
  <div
    class="relative w-full  max-w-6xl overflow-hidden rounded-[24px] border border-cyan-500/20 px-6 py-10 shadow-[0_0_80px_rgba(0,0,0,0.35)] md:px-10 lg:px-12"
  >
    <SmartImage
      src="/blogs/Story-Back.webp"
      className="absolute inset-0 h-full w-full object-cover opacity-50"
      client:load
    />

    <div class="absolute inset-0 bg-white/5 backdrop-blur-md"></div>

    <div class="relative z-10 grid gap-10 lg:grid-cols-[1fr_2fr] lg:items-center">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-5">
          <h2
            class="text-3xl font-semibold leading-tight text-white md:text-4xl"
          >
            We design <span class="text-[#1EAFB1]">Product Stories</span> not just
            animations.
          </h2>

          <div
            class="space-y-1 text-sm leading-relaxed text-white/80 md:text-base"
          >
            <h4>We don't just move screens around.</h4>
            <h4>
              We craft structured narratives that explain, persuade, and
              convert.
            </h4>
          </div>
        </div>

        <div
          class="h-px w-full bg-gradient-to-r from-transparent via-[#00A9BD] to-transparent"
        >
        </div>

        <div class="space-y-4">
          {
            data.map((item) => (
              <div class="flex items-center gap-3">
                <CheckCircle
                  size={28}
                  strokeWidth={1.75}
                  color="#1EAFB1"
                  className="shrink-0"
                />
                <h3 class="text-lg text-white/90">{item.title}</h3>
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex items-center justify-center lg:justify-end">
        <div class="relative w-full aspect-[1200/900] lg:aspect-[1200/800]">
          <div class="absolute inset-0 z-1 animate-felash-entry [animation-delay:1000ms]">
            <SmartImage src="/pricing/svg/Felash-1.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-1 animate-felash-entry [animation-delay:1100ms]">
            <SmartImage src="/pricing/svg/Felash-2.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-1 animate-felash-entry [animation-delay:1200ms]">
            <SmartImage src="/pricing/svg/Felash-3.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-2 animate-design-entry [animation-delay:1400ms]">
            <SmartImage src="/pricing/svg/1.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-3 animate-design-entry [animation-delay:1500ms]">
            <SmartImage src="/pricing/svg/2.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-4 animate-design-entry [animation-delay:1600ms]">
            <SmartImage src="/pricing/svg/3.svg" client:visible />
          </div>
          <div class="absolute inset-0 z-5 animate-design-entry [animation-delay:1700ms]">
            <SmartImage src="/pricing/svg/4.svg" client:visible />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes design-entry {
    0% {
      opacity: 0;
      transform: translateY(24px) scale(0.92);
      filter: blur(4px);
    }
    60% {
      opacity: 1;
      transform: translateY(-4px) scale(1.01);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .animate-design-entry {
    animation: design-entry 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    opacity: 0;
    will-change: transform, opacity, filter;
  }

  .animate-felash-entry {
    animation: felash-entry 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
    will-change: transform, opacity;
  }

  @keyframes felash-entry {
    0% {
      opacity: 0;
      transform: translateX(-40px) scale(0.7);
    }
    50% {
      opacity: 1;
      transform: translateX(6px) scale(1.04);
    }
    75% {
      transform: translateX(-3px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-design-entry,
    .animate-felash-entry {
      animation: none;
      opacity: 1;
    }
  }
</style>
