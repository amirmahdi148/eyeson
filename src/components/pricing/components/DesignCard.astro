---
import { CheckCircle } from "lucide-react";
import { SmartImage } from "@/utils/SmartImage.tsx";

const data = [
  { title: "Strategy-first scripting" },
  { title: "UI-native motion design" },
  { title: "Built specially for SaaS" },
  { title: "Clarity over flashy effects" },
];
---

<div class="w-full flex items-center justify-center px-4 py-10">
  <div
    class="relative w-full max-w-6xl overflow-hidden rounded-[24px] border border-cyan-500/20 px-6 py-10 shadow-[0_0_80px_rgba(0,0,0,0.35)] md:px-10 lg:px-12"
  >
    <SmartImage
      src="/blogs/Story-Back.webp"
      className="absolute inset-0 h-full w-full object-cover opacity-40"
      client:load
    />

    <div class="absolute inset-0 bg-white/5 backdrop-blur-md"></div>

    <div class="relative z-10 grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-5">
          <h2
            class="text-3xl font-semibold leading-tight text-white md:text-4xl"
          >
            We design <span class="text-[#1EAFB1]">Product Stories</span> not just
            animations.
          </h2>

          <div
            class="space-y-1 text-sm leading-relaxed text-white/80 md:text-base"
          >
            <h4>We don't just move screens around.</h4>
            <h4>
              We craft structured narratives that explain, persuade, and
              convert.
            </h4>
          </div>
        </div>

        <div
          class="h-px w-full bg-gradient-to-r from-transparent via-[#00A9BD] to-transparent"
        >
        </div>

        <div class="space-y-4">
          {
            data.map((item) => (
              <div class="flex items-center gap-3">
                <CheckCircle
                  size={28}
                  strokeWidth={1.75}
                  color="#1EAFB1"
                  className="shrink-0"
                />
                <h3 class="text-lg text-white/90">{item.title}</h3>
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex items-center justify-center lg:justify-end">
        <div class="relative w-full max-w-[560px]">
          <SmartImage
            src="/pricing/card.webp"
            width={900}
            height={600}
            client:visible
          />
        </div>
      </div>
    </div>
  </div>
</div>
