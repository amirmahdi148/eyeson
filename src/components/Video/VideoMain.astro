---
import ContactUs from "../../islands/ContactUs";
import FeaturesSection from "../Shared/FeaturesSection.astro";
import LogoCaro from "../Shared/LogoCaro.astro";
import StarBackground from "../../islands/StarBackground";
import VideoEditingSection from "../../islands/Video/VideoEditingSection";
import CostVideo from "../Shared/CostVideo.astro";
import {VideoNeedsBlock} from "../../islands/Video/VideoNeedsBlock.tsx";
import VideoServicesSection from "../../islands/Video/VideoServicesSection";
import VideoWorkShowcaseSection from "../../islands/Shared/VideoWorkShowcaseSection";
import CaseStudiesSection from "../../islands/CaseStudiesSection";
import ApproachTimelineSection from "../../islands/Video/ApproachTimelineSection";
import VideoPackagesSection from "../../islands/Video/VideoPackagesSection";
import WhatsIncludedSection from "../../islands/Video/WhatsIncludedSection";
import VideoBackground from "./VideoBackground.astro";
import { VideoHeader } from "../../islands/Shared/VideoHeader";
---


<main class="relative w-full min-h-screen overflow-hidden">


        <VideoBackground/>








    <StarBackground />


    <VideoHeader

    BeforeHighlight=""
    Highlight="Video Editing"
    AfterHighlight={`That Turns
    Raw Footage Into Scroll-Stopping Content`}
    Description="Professional video editing and talking head editing for creators, founders, SaaS companies,
podcasts, YouTube channels, and personal brands that want stronger engagement, better
watch time, and content built to perform across modern social media platforms."


    imageUrl="/video-pieces/person.webp"


    primaryBtnText="View Editing Samples"
    primaryBtnUrl="/portfolio"
    secondaryBtnText="Book a Call"
    secondaryBtnUrl="/contact"


    enableImageHover={true}


    showBackground={true}
    backgroundClassName="
    bg-[linear-gradient(to_bottom,#010e17_0%,#01343a_35%,#34776c_65%,rgba(52,119,108,0.6)_80%,rgba(52,119,108,0.25)_90%,transparent_100%)]
    "
    

    headingClassName="text-3xl sm:text-3xl lg:text-4xl font-extrabold"
    highlightClassName="text-[#39d0c3]"

    textContainerClassName="space-y-5"


    primaryBtnWrapperClassName="bg-gradient-to-r from-[#0fe0d2] to-[#08717e] p-[2px] rounded-full"
    primaryBtnClassName="bg-gradient-to-r from-[#00A9BD] to-[#1D553A] text-white px-6 py-3"

    secondaryBtnWrapperClassName="bg-gradient-to-r from-[#08717e] to-[#40ae90] p-[2px] rounded-full"
    secondaryBtnClassName="bg-gradient-to-r from-[#00061D] to-[#0B1F2A] text-white px-6 py-3"


    imageWrapperClassName="rounded-3xl overflow-hidden w-80 md:w-140"
    client:load
    />
    <LogoCaro />
    <VideoEditingSection client:load/>
    <FeaturesSection title="Smart Video Editing" highlight="Built for Attention, Virality, and Social Growth" description="Modern content moves fast. Strong editing is no longer just about cutting clips together, it is
about pacing, attention, clarity, storytelling, and understanding how people actually
consume content online.
At EyesOn Studio, we create edits designed for modern platforms, helping creators,
founders, SaaS brands, podcasts, and media teams turn raw footage into cleaner, sharper,
and more engaging content that performs better across social media."/>
    <VideoNeedsBlock client:load />
    <VideoServicesSection client:load/>
    <WhatsIncludedSection client:load/>
    <ApproachTimelineSection client:load />
    <VideoWorkShowcaseSection client:load />
    <VideoPackagesSection client:load/>
    <CaseStudiesSection client:load />
    <CostVideo  />

    <ContactUs client:load />

</main>
