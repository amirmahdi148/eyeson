---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BlogHero } from "../../islands/Blogs/BlogHero";

export const prerender = false;

const API_URL = "http://localhost:1337";
const API_POSTS = `${API_URL}/api/posts`;



const { slug } = Astro.params;

console.log("[blog slug] Requested slug:", slug);

let postData = null;
let blocks = [];
let coverUrl = null;

const url = `${API_POSTS}?filters[slug][$eq]=${encodeURIComponent(slug || "")}&populate=*`;
console.log("[blog slug] Fetching:", url);

try {
  const res = await fetch(url);
  console.log("[blog slug] Response status:", res.status, res.statusText);
  const json = await res.json();
  console.log("[blog slug] Response data count:", json.data?.length, "| meta:", JSON.stringify(json.meta));
  const post = json.data?.[0];
  if (post) {
    console.log("[blog slug] Found post:", post.title, "| slug:", post.slug);
    postData = post;
    blocks = post.content || [];

    const cover = post.cover;
    if (cover?.url) {
      coverUrl = cover.url.startsWith("http") ? cover.url : `${API_URL}${cover.url}`;
      console.log("[blog slug] Cover image:", coverUrl);
    } else {
      console.log("[blog slug] No cover image");
    }
  } else {
    console.log("[blog slug] No post found for slug:", slug);
  }
} catch (err) {
  console.error("[blog slug] Fetch failed:", err);
  postData = null;
}

---

<BaseLayout title={postData?.title || "Blog Post"}>
    <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(0,169,189,0.18),transparent_28%),radial-gradient(circle_at_80%_28%,rgba(0,169,189,0.18),transparent_26%),radial-gradient(circle_at_50%_115%,rgba(0,169,189,0.2),transparent_34%)]" />
        <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.15),rgba(0,0,0,0.4))]" />
        <div class="absolute inset-0 opacity-35 bg-[radial-gradient(rgba(255,255,255,0.45)_1px,transparent_1px)] bg-size-[115px_115px]" />
    </div>
  {
    postData ? (

      <BlogHero
        client:load
        title={postData.title}
        category={postData.category}
        date={postData.publishedAt}
        readTime={postData.readTime}
        image={coverUrl}
        blocks={blocks}
      />
    ) : (
      <div class="flex min-h-screen items-center justify-center text-white">
        <p>Post not found.</p>
      </div>
    )
  }
</BaseLayout>
