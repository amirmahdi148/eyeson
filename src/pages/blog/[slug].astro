---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BlogHero } from "../../islands/Blogs/BlogHero";

export const prerender = false;

const STRAPI_URL = import.meta.env.PUBLIC_POST_URL || "http://localhost:1337";
const API_POSTS = `${STRAPI_URL}/api/posts`;
const SITE_URL = "https://eyeson.com";

const { slug } = Astro.params;

let postData = null;
let blocks = [];
let coverUrl = null;
let absoluteCoverUrl = undefined;
let postDescription = "";
let postKeywords = "";

const url = `${API_POSTS}?filters[slug][$eq]=${encodeURIComponent(slug || "")}&populate=*`;

try {
  const res = await fetch(url);
  const json = await res.json();
  const post = json.data?.[0];
  if (post) {
    postData = post;
    blocks = post.content || [];

    const cover = post.cover;
    if (cover?.url) {
      coverUrl = cover.url.startsWith("http") ? cover.url : `${STRAPI_URL}${cover.url}`;
      absoluteCoverUrl = coverUrl.startsWith("http") ? coverUrl : `${SITE_URL}${coverUrl}`;
    }

    postDescription = post.excerpt || "";
    postKeywords = post.keywords || "";
  }
} catch (err) {
  console.error("[blog slug] Fetch failed:", err);
  postData = null;
}

---

<BaseLayout
  title={postData?.title ? `${postData.title} — EyesOn Agency` : "Blog Post — EyesOn Agency"}
  description={postDescription || postData?.title || "Blog post"}
  ogImage={absoluteCoverUrl}
  canonicalUrl={`${SITE_URL}/blog/${slug}`}
  ogType="article"
  keywords={postKeywords}
  datePublished={postData?.publishedAt || undefined}
  dateModified={postData?.publishedAt || undefined}
  articleSection={postData?.category || undefined}
>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": postData?.title || "Blog Post",
      "description": postDescription || postData?.title || "",
      "image": absoluteCoverUrl || `${SITE_URL}/og/image.jpg`,
      "datePublished": postData?.publishedAt || "",
      "dateModified": postData?.publishedAt || "",
      "author": {
        "@type": "Organization",
        "name": "EyesOn Studio",
        "url": SITE_URL
      },
      "publisher": {
        "@type": "Organization",
        "name": "EyesOn Agency",
        "logo": {
          "@type": "ImageObject",
          "url": `${SITE_URL}/og/image.jpg`
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `${SITE_URL}/blog/${slug}`
      }
    })} />
    <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(0,169,189,0.18),transparent_28%),radial-gradient(circle_at_80%_28%,rgba(0,169,189,0.18),transparent_26%),radial-gradient(circle_at_50%_115%,rgba(0,169,189,0.2),transparent_34%)]" />
        <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.15),rgba(0,0,0,0.4))]" />
        <div class="absolute inset-0 opacity-35 bg-[radial-gradient(rgba(255,255,255,0.45)_1px,transparent_1px)] bg-size-[115px_115px]" />
    </div>
  {
    postData ? (

      <BlogHero
        client:load
        title={postData.title}
        category={postData.category}
        date={postData.publishedAt}
        readTime={postData.readTime}
        image={coverUrl}
        blocks={blocks}
        slug={postData.slug}
      />
    ) : (
      <div class="flex min-h-screen items-center justify-center text-white">
        <p>Post not found.</p>
      </div>
    )
  }
</BaseLayout>
