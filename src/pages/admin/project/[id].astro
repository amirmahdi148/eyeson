---
export const prerender = true;
import AdminBaseLayout from "../../../layouts/AdminLayout.astro";
import AdminLayout from "@/islands/Admin/AdminLayout";
import AdminGuard from "@/islands/Admin/AdminGuard";

export async function getStaticPaths() {
  return [{ params: { id: "example" } }];
}

const { id } = Astro.params;
---
<AdminBaseLayout>
  <AdminGuard client:only="react">
    <AdminLayout client:load>
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-bold text-white">Project: {id}</h2>
            <p class="text-sm text-white/50 mt-0.5">Manage project details and assets</p>
          </div>
          <a class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-white/10 text-white/70 text-sm font-medium hover:bg-white/5 transition-colors" href="/admin/projects">
            ← Back to Projects
          </a>
        </div>

        <div class="rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-xl p-6 sm:p-8">
          <div class="text-center py-12">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#00E6D7]/20 to-[#12ACB5]/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-[#00E6D7]">{id?.charAt(0).toUpperCase()}</span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">Project Editor</h3>
            <p class="text-sm text-white/40 max-w-md mx-auto">
              Implement forms to add images, metadata, and other details for this project.
            </p>
          </div>
        </div>
      </div>
    </AdminLayout>
  </AdminGuard>
</AdminBaseLayout>
