---
export async function getStaticPaths() {
  return [
    { params: { id: 'example' } },
  ];
}

const { id } = Astro.params;
---
<div class="min-h-screen p-6 bg-[radial-gradient(ellipse_at_top_right,_#062428,_#001219)] text-white">
  <div class="max-w-4xl mx-auto bg-white/5 p-8 rounded-2xl backdrop-blur-xl border border-white/6">
    <h1 class="text-2xl font-bold mb-4">Project: {id}</h1>
    <p class="text-sm text-white/70 mb-4">This is a placeholder project edit page. Implement forms to add images, metadata and other details here.</p>
    <div class="flex gap-2">
      <a class="px-3 py-2 rounded-full bg-gradient-to-r from-[#00E6D7] to-[#12ACB5] text-black" href="/admin/projects">Back to projects</a>
    </div>
  </div>
</div>
