---
export const prerender = true;
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 Not Found — EyesOn Agency</title>
    <meta
      name="description"
      content="The page you were looking for does not exist. Return to EyesOn Agency or browse our work."
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#000E17" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/webp" href="/logo.webp" />
  </head>
  <body class="overflow-x-hidden bg-[#000E17] text-white">
    <main class="relative isolate min-h-screen overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(49,209,166,0.18),transparent_38%),radial-gradient(circle_at_80%_20%,rgba(37,174,178,0.18),transparent_24%),linear-gradient(180deg,#000E17_0%,#031824_52%,#000E17_100%)]"></div>
      <div class="absolute inset-0 opacity-70">
        <div class="absolute left-[-8%] top-[12%] h-72 w-72 rounded-full bg-[#00A9BD]/20 blur-3xl"></div>
        <div class="absolute right-[-10%] top-[45%] h-96 w-96 rounded-full bg-[#31d1a6]/10 blur-3xl"></div>
        <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
      </div>

      <div class="relative mx-auto flex min-h-screen w-full max-w-7xl items-center px-6 py-20 sm:px-10 lg:px-12">
        <div class="grid w-full gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium uppercase tracking-[0.35em] text-white/70 backdrop-blur">
              Lost in the signal
            </p>

            <h1 class="text-balance text-6xl font-semibold tracking-tight text-white sm:text-7xl lg:text-8xl">
              404
              <span class="mt-3 block text-3xl font-medium text-white/80 sm:text-4xl lg:text-5xl">
                Page not found
              </span>
            </h1>

            <p class="mt-6 max-w-xl text-pretty text-base leading-8 text-white/70 sm:text-lg">
              The page you requested drifted out of orbit.
              We can get you back to the main site, or you can head straight to the work that defines EyesOn.
            </p>

            <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
              <a
                href="/"
                class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-[#00A9BD] to-[#31d1a6] px-7 py-3.5 text-sm font-semibold text-[#00161f] shadow-[0_0_35px_rgba(0,169,189,0.25)] transition-transform duration-300 hover:-translate-y-0.5"
              >
                Back to home
              </a>
              <a
                href="/portfolio"
                class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-7 py-3.5 text-sm font-semibold text-white/90 backdrop-blur transition-colors duration-300 hover:border-white/25 hover:bg-white/10"
              >
                Explore portfolio
              </a>
            </div>

            <div class="mt-12 grid gap-4 sm:grid-cols-3">
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                <p class="text-xs uppercase tracking-[0.3em] text-white/45">Fast route</p>
                <p class="mt-2 text-sm leading-6 text-white/80">Use the home page or portfolio to continue browsing.</p>
              </div>
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                <p class="text-xs uppercase tracking-[0.3em] text-white/45">Current path</p>
                <p class="mt-2 break-all text-sm leading-6 text-white/80">{Astro.url.pathname}</p>
              </div>
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                <p class="text-xs uppercase tracking-[0.3em] text-white/45">Need help?</p>
                <p class="mt-2 text-sm leading-6 text-white/80">
                  Try the contact page if you were looking for something specific.
                </p>
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="absolute inset-0 rounded-[2rem] bg-[radial-gradient(circle_at_center,rgba(49,209,166,0.22),transparent_55%)] blur-2xl"></div>
            <div class="relative rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-[0_30px_120px_rgba(0,0,0,0.35)] backdrop-blur-xl">
              <div class="flex items-center justify-between border-b border-white/10 pb-4">
                <span class="text-xs uppercase tracking-[0.35em] text-white/45">Signal status</span>
                <span class="rounded-full border border-amber-400/25 bg-amber-400/10 px-3 py-1 text-xs font-medium text-amber-200">
                  404
                </span>
              </div>

              <div class="py-8">
                <div class="relative mx-auto flex aspect-square max-w-md items-center justify-center">
                  <div class="absolute inset-0 rounded-full border border-white/10"></div>
                  <div class="absolute inset-6 rounded-full border border-dashed border-[#31d1a6]/30"></div>
                  <div class="absolute inset-14 rounded-full border border-white/10"></div>

                  <div class="absolute inset-0 animate-[spin_24s_linear_infinite]">
                    <div class="absolute left-1/2 top-0 h-3 w-3 -translate-x-1/2 rounded-full bg-[#31d1a6] shadow-[0_0_24px_rgba(49,209,166,0.9)]"></div>
                  </div>

                  <div class="relative z-10 text-center">
                    <p class="text-[7rem] font-semibold leading-none text-white sm:text-[8rem]">404</p>
                    <p class="mt-3 text-sm uppercase tracking-[0.4em] text-white/50">Not found in this sector</p>
                  </div>
                </div>
              </div>

              <div class="grid gap-3 border-t border-white/10 pt-4 sm:grid-cols-2">
                <a
                  href="/contact"
                  class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-white/85 transition-colors duration-300 hover:border-white/20 hover:bg-white/10"
                >
                  Contact us
                </a>
                <a
                  href="/blogs"
                  class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-white/85 transition-colors duration-300 hover:border-white/20 hover:bg-white/10"
                >
                  Read insights
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
